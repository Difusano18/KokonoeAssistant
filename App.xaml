<Application x:Class="KokonoeAssistant.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>

        <!-- ═══ FUTURISTIC SURFACES ═════════════════════════════════ -->
        <Color  x:Key="C_Bg0">#080B10</Color>
        <Color  x:Key="C_Bg1">#0B1017</Color>
        <Color  x:Key="C_Bg2">#111821</Color>
        <Color  x:Key="C_Bg3">#17212C</Color>
        <Color  x:Key="C_Bg4">#223040</Color>

        <SolidColorBrush x:Key="AccentBgMain"      Color="#080B10"/>
        <SolidColorBrush x:Key="AccentBgBase"      Color="#0B1017"/>
        <SolidColorBrush x:Key="AccentBgPanel"     Color="#111821"/>
        <SolidColorBrush x:Key="AccentBgCard"      Color="#17212C"/>
        <SolidColorBrush x:Key="AccentBgHover"     Color="#223040"/>
        <SolidColorBrush x:Key="AccentBgDarker"    Color="#06080C"/>
        <SolidColorBrush x:Key="AccentBgInput"     Color="#E00C1219"/>
        <SolidColorBrush x:Key="AccentBgSystem"    Color="#D1121B24"/>

        <LinearGradientBrush x:Key="KokoWindowBackground" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FE080B10" Offset="0"/>
            <GradientStop Color="#FE0D131B" Offset="0.44"/>
            <GradientStop Color="#FE070A0F" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="KokoHeaderBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#F60B1017" Offset="0"/>
            <GradientStop Color="#F2121A23" Offset="0.50"/>
            <GradientStop Color="#F6090D13" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="KokoSidebarBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#F20B1017" Offset="0"/>
            <GradientStop Color="#ED080B10" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="KokoFooterBrush" Color="#F00A0E14"/>
        <SolidColorBrush x:Key="KokoInputPanelBrush" Color="#E00D141C"/>
        <SolidColorBrush x:Key="KokoCardBrush" Color="#E1111922"/>
        <SolidColorBrush x:Key="KokoCardElevatedBrush" Color="#F116202B"/>
        <SolidColorBrush x:Key="KokoCardSoftBrush" Color="#99141D27"/>
        <SolidColorBrush x:Key="KokoHairlineBrush" Color="#2B3644"/>
        <SolidColorBrush x:Key="KokoSurfaceInsetBrush" Color="#CC090D13"/>
        <SolidColorBrush x:Key="KokoSurfaceRaisedBrush" Color="#F317222E"/>
        <SolidColorBrush x:Key="KokoChatCanvasBrush" Color="#8A0A0F15"/>

        <!-- Glass panel (semi-transparent card) -->
        <SolidColorBrush x:Key="AccentGlass"       Color="#17212C" Opacity="0.88"/>

        <!-- ═══ BORDERS / LINES ════════════════════════════════════ -->
        <SolidColorBrush x:Key="AccentBgBorder"    Color="#263241"/>
        <SolidColorBrush x:Key="AccentBgBorder1"   Color="#314052"/>
        <SolidColorBrush x:Key="AccentBgBorder2"   Color="#3A4654"/>
        <SolidColorBrush x:Key="AccentAsstBorder"  Color="#4B6472"/>
        <SolidColorBrush x:Key="AccentAmberLine"   Color="#8B724A"/>

        <!-- ═══ CYAN / VIOLET ACCENTS ═══════════════════════════════ -->
        <Color  x:Key="C_Amber">#C7A66B</Color>
        <Color  x:Key="C_AmberHi">#E3C98D</Color>
        <Color  x:Key="C_AmberLo">#80643B</Color>

        <SolidColorBrush x:Key="AccentBase"        Color="#5CB7AA"/>
        <Color           x:Key="AccentBaseColor"    >#5CB7AA</Color>
        <SolidColorBrush x:Key="AccentPrimary"     Color="#C7A66B"/>
        <SolidColorBrush x:Key="AccentDark"        Color="#8A5361"/>
        <SolidColorBrush x:Key="AccentPale"        Color="#E3C98D"/>
        <SolidColorBrush x:Key="AccentText"        Color="#C5CED8"/>
        <SolidColorBrush x:Key="AccentTextLight"   Color="#EEF3F7"/>
        <SolidColorBrush x:Key="AccentVeryLight"   Color="#FFFFFF"/>
        <SolidColorBrush x:Key="AccentMuted"       Color="#8793A0"/>
        <SolidColorBrush x:Key="AccentDim"         Color="#5C6875"/>
        <SolidColorBrush x:Key="AccentNavBg"       Color="#FFFFFF0A"/>
        <SolidColorBrush x:Key="AccentUserBubble"  Color="#213D4A"/>
        <SolidColorBrush x:Key="AccentUserShadow"  Color="#5CB7AA"/>
        <SolidColorBrush x:Key="AccentAsstBubble"  Color="#E00F151D"/>
        <SolidColorBrush x:Key="AccentAsstTime"    Color="#788490"/>
        <SolidColorBrush x:Key="AccentScrollThm"   Color="#5CB7AA66"/>
        <SolidColorBrush x:Key="AccentListHovBg"   Color="#FFFFFF08"/>

        <Color x:Key="RgbRedColor">#D96570</Color>
        <Color x:Key="RgbGreenColor">#5CB7AA</Color>
        <Color x:Key="RgbBlueColor">#6EA8D8</Color>
        <SolidColorBrush x:Key="RgbRedBrush"   Color="{StaticResource RgbRedColor}"/>
        <SolidColorBrush x:Key="RgbGreenBrush" Color="{StaticResource RgbGreenColor}"/>
        <SolidColorBrush x:Key="RgbBlueBrush"  Color="{StaticResource RgbBlueColor}"/>
        <SolidColorBrush x:Key="KokoMetricBrush" Color="#DDE5EC"/>
        <SolidColorBrush x:Key="KokoSubtleTextBrush" Color="#A0ABB6"/>

        <!-- ═══ STATUS COLORS ═══════════════════════════════════════ -->
        <SolidColorBrush x:Key="Brush_Ok"          Color="#5CB7AA"/>
        <SolidColorBrush x:Key="Brush_Err"         Color="#D96570"/>
        <SolidColorBrush x:Key="Brush_Info"        Color="#6EA8D8"/>
        <SolidColorBrush x:Key="Brush_Warn"        Color="#C7A66B"/>

        <!-- Legacy compatibility aliases (code-behind references) -->
        <SolidColorBrush x:Key="Brush_030B05"      Color="#1A0F00"/>
        <SolidColorBrush x:Key="Brush_8AC8A0"      Color="#C9D7EA"/>
        <SolidColorBrush x:Key="Brush_1A3020"      Color="#585548"/>
        <SolidColorBrush x:Key="Brush_2A4232"      Color="#8A8678"/>
        <SolidColorBrush x:Key="Brush_163025"      Color="#FFB02040"/>
        <SolidColorBrush x:Key="Brush_142018"      Color="#58657A"/>
        <SolidColorBrush x:Key="Brush_2A4030"      Color="#3A382F"/>
        <SolidColorBrush x:Key="Brush_071209"      Color="#10111D"/>
        <SolidColorBrush x:Key="Brush_0A1A0D"      Color="#141923"/>
        <SolidColorBrush x:Key="Brush_08180C"      Color="#141923"/>
        <SolidColorBrush x:Key="Brush_071008"      Color="#07090D"/>
        <SolidColorBrush x:Key="Brush_0F2818"      Color="#FFB02029"/>
        <SolidColorBrush x:Key="Brush_060F08"      Color="#0F131B"/>
        <SolidColorBrush x:Key="Brush_2A0808"      Color="#2A0A0A"/>
        <SolidColorBrush x:Key="Brush_FF5555"      Color="#E26565"/>
        <SolidColorBrush x:Key="Brush_2A4832"      Color="#585548"/>
        <SolidColorBrush x:Key="Brush_2A5038"      Color="#A8C3D8"/>
        <SolidColorBrush x:Key="Brush_3A2020"      Color="#8A8678"/>
        <SolidColorBrush x:Key="Brush_102818"      Color="#FFB0201F"/>
        <SolidColorBrush x:Key="Brush_050D07"      Color="#090A13"/>
        <SolidColorBrush x:Key="Brush_2A6040"      Color="#8A8678"/>

        <!-- ═══ SCROLLBAR ══════════════════════════════════════════ -->
        <Style x:Key="KokoScrollThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{DynamicResource AccentScrollThm}" CornerRadius="2"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource KokoScrollThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ BUTTON: Primary ════════════════════════════════════ -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#24544F" Offset="0"/>
                        <GradientStop Color="#2D4A48" Offset="0.58"/>
                        <GradientStop Color="#5B4D31" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground"      Value="#F8FBFF"/>
            <Setter Property="BorderBrush"     Value="#6E7F86"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="MinHeight"       Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="12" ShadowDepth="1" Opacity="0.22"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#000000" BlurRadius="14" ShadowDepth="1" Opacity="0.28"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ BUTTON: Ghost ═════════════════════════════════════ -->
        <Style x:Key="BtnGhost" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource AccentMuted}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource AccentBgBorder2}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="MinHeight"       Value="30"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FFFFFF0C"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource AccentAsstBorder}"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentText}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ BUTTON: Nav (sidebar) ════════════════════════════ -->
        <Style x:Key="BtnNav" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource AccentText}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Height"          Value="40"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="7" Margin="0,2"
                                BorderBrush="Transparent" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"
                                               Margin="11,0,0,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FFFFFF08"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource AccentBgBorder1}"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentTextLight}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnNavActive" TargetType="Button">
            <Setter Property="Foreground"      Value="{DynamicResource AccentTextLight}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Height"          Value="40"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="bd" CornerRadius="7" Margin="0,2"
                                    BorderBrush="#5B707C" BorderThickness="1">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#1B2A32" Offset="0"/>
                                        <GradientStop Color="#151F29" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" BlurRadius="12" ShadowDepth="1" Opacity="0.26"/>
                                </Border.Effect>
                                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"
                                                   Margin="15,0,0,0"/>
                            </Border>
                            <Rectangle Width="2" HorizontalAlignment="Left" RadiusX="2" RadiusY="2"
                                       Fill="{DynamicResource AccentBase}" Margin="0,9,0,9">
                                <Rectangle.Effect>
                                    <DropShadowEffect Color="#5CB7AA" BlurRadius="8" ShadowDepth="0" Opacity="0.40"/>
                                </Rectangle.Effect>
                            </Rectangle>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Aliases for code-behind Tab_Click compatibility -->
        <Style x:Key="BtnTab"       TargetType="Button" BasedOn="{StaticResource BtnNav}"/>
        <Style x:Key="BtnTabActive" TargetType="Button" BasedOn="{StaticResource BtnNavActive}"/>

        <!-- ═══ BUTTON: Chrome (titlebar) ════════════════════════ -->
        <Style x:Key="ChromeBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource AccentMuted}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="32"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FFFFFF0C"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentTextLight}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ TEXTBOX ══════════════════════════════════════════ -->
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background"      Value="{DynamicResource AccentBgInput}"/>
            <Setter Property="Foreground"      Value="{DynamicResource AccentTextLight}"/>
            <Setter Property="CaretBrush"      Value="{DynamicResource AccentBase}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource AccentBgBorder2}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontFamily"      Value="Segoe UI Variable, Segoe UI"/>
            <Setter Property="Padding"         Value="12,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="10" ShadowDepth="1" Opacity="0"/>
                            </Border.Effect>
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource AccentBase}"/>
                                <Setter TargetName="bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#000000" BlurRadius="14" ShadowDepth="1" Opacity="0.28"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ LISTBOX ══════════════════════════════════════════ -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="Foreground"   Value="{DynamicResource AccentText}"/>
            <Setter Property="Padding"      Value="8,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FFFFFF08"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentNavBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ SETTINGS STYLES (SettingsWindow) ════════════════ -->
        <Style x:Key="SettingsSectionHeader" TargetType="TextBlock">
            <Setter Property="FontFamily"  Value="Consolas"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="Normal"/>
            <Setter Property="Foreground"  Value="{DynamicResource AccentDim}"/>
            <Setter Property="Margin"      Value="0,18,0,8"/>
        </Style>

        <Style x:Key="SettingsLabel" TargetType="TextBlock">
            <Setter Property="FontFamily"  Value="Segoe UI Variable, Segoe UI"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="Foreground"  Value="{DynamicResource AccentMuted}"/>
            <Setter Property="Margin"      Value="0,0,0,4"/>
        </Style>

        <Style x:Key="SettingInput" TargetType="TextBox">
            <Setter Property="Background"      Value="#1B212D"/>
            <Setter Property="Foreground"      Value="{DynamicResource AccentTextLight}"/>
            <Setter Property="CaretBrush"      Value="{DynamicResource AccentBase}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource AccentBgBorder2}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily"      Value="Segoe UI Variable, Segoe UI"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Padding"         Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource AccentBase}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingComboBox" TargetType="ComboBox">
            <Setter Property="Background"      Value="#1B212D"/>
            <Setter Property="Foreground"      Value="{DynamicResource AccentTextLight}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource AccentBgBorder2}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily"      Value="Segoe UI Variable, Segoe UI"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Padding"         Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="toggle"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          Focusable="false"
                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="bd"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4">
                                            <ContentPresenter Margin="8,4"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource AccentBase}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <Border Padding="8,6">
                                    <Grid>
                                        <ContentPresenter Content="{TemplateBinding Text}"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,20,0"/>
                                        <Path x:Name="arrow"
                                              Data="M0,0 L4,4 L8,0 Z"
                                              Fill="{DynamicResource AccentMuted}"
                                              HorizontalAlignment="Right"
                                              VerticalAlignment="Center"
                                              Margin="0,0,8,0"/>
                                    </Grid>
                                </Border>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   PopupAnimation="Slide"
                                   AllowsTransparency="True"
                                   IsOpen="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <Border Background="#141923"
                                        BorderBrush="{DynamicResource AccentBgBorder2}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Margin="0,4,0,0">
                                    <ScrollViewer MaxHeight="300">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
