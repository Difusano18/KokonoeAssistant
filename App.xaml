<Application x:Class="KokonoeAssistant.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>

        <!-- ═══ FUTURISTIC SURFACES ═════════════════════════════════ -->
        <Color  x:Key="C_Bg0">#050713</Color>
        <Color  x:Key="C_Bg1">#080B16</Color>
        <Color  x:Key="C_Bg2">#0C1324</Color>
        <Color  x:Key="C_Bg3">#111A2D</Color>
        <Color  x:Key="C_Bg4">#17243A</Color>

        <SolidColorBrush x:Key="AccentBgMain"      Color="#050713"/>
        <SolidColorBrush x:Key="AccentBgBase"      Color="#080B16"/>
        <SolidColorBrush x:Key="AccentBgPanel"     Color="#0C1324"/>
        <SolidColorBrush x:Key="AccentBgCard"      Color="#111A2D"/>
        <SolidColorBrush x:Key="AccentBgHover"     Color="#17243A"/>
        <SolidColorBrush x:Key="AccentBgDarker"    Color="#060916"/>
        <SolidColorBrush x:Key="AccentBgInput"     Color="#A0081020"/>
        <SolidColorBrush x:Key="AccentBgSystem"    Color="#99111A2D"/>

        <LinearGradientBrush x:Key="KokoWindowBackground" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F2050713" Offset="0"/>
            <GradientStop Color="#F20A1020" Offset="0.58"/>
            <GradientStop Color="#F2070715" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="KokoHeaderBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#F0080B16" Offset="0"/>
            <GradientStop Color="#E90D1830" Offset="0.55"/>
            <GradientStop Color="#F0080B16" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="KokoSidebarBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E9090D1A" Offset="0"/>
            <GradientStop Color="#D8060A14" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="KokoFooterBrush" Color="#EA080B16"/>
        <SolidColorBrush x:Key="KokoInputPanelBrush" Color="#B00A1020"/>
        <SolidColorBrush x:Key="KokoCardBrush" Color="#A0111A2D"/>

        <!-- Glass panel (semi-transparent card) -->
        <SolidColorBrush x:Key="AccentGlass"       Color="#111A2D" Opacity="0.86"/>

        <!-- ═══ BORDERS / LINES ════════════════════════════════════ -->
        <SolidColorBrush x:Key="AccentBgBorder"    Color="#22D3EE18"/>
        <SolidColorBrush x:Key="AccentBgBorder1"   Color="#22D3EE24"/>
        <SolidColorBrush x:Key="AccentBgBorder2"   Color="#A78BFA30"/>
        <SolidColorBrush x:Key="AccentAsstBorder"  Color="#22D3EE66"/>
        <SolidColorBrush x:Key="AccentAmberLine"   Color="#FBBF2466"/>

        <!-- ═══ CYAN / VIOLET ACCENTS ═══════════════════════════════ -->
        <Color  x:Key="C_Amber">#FBBF24</Color>
        <Color  x:Key="C_AmberHi">#FDE68A</Color>
        <Color  x:Key="C_AmberLo">#D97706</Color>

        <SolidColorBrush x:Key="AccentBase"        Color="#22D3EE"/>
        <Color           x:Key="AccentBaseColor"    >#22D3EE</Color>
        <SolidColorBrush x:Key="AccentPrimary"     Color="#A78BFA"/>
        <SolidColorBrush x:Key="AccentDark"        Color="#7C3AED"/>
        <SolidColorBrush x:Key="AccentPale"        Color="#C4B5FD"/>
        <SolidColorBrush x:Key="AccentText"        Color="#C9D7EA"/>
        <SolidColorBrush x:Key="AccentTextLight"   Color="#F4F8FF"/>
        <SolidColorBrush x:Key="AccentVeryLight"   Color="#FFFFFF"/>
        <SolidColorBrush x:Key="AccentMuted"       Color="#8FA3BE"/>
        <SolidColorBrush x:Key="AccentDim"         Color="#58657A"/>
        <SolidColorBrush x:Key="AccentNavBg"       Color="#A78BFA22"/>
        <SolidColorBrush x:Key="AccentUserBubble"  Color="#5B2E91"/>
        <SolidColorBrush x:Key="AccentUserShadow"  Color="#7C3AED"/>
        <SolidColorBrush x:Key="AccentAsstBubble"  Color="#B0061424"/>
        <SolidColorBrush x:Key="AccentAsstTime"    Color="#6F829A"/>
        <SolidColorBrush x:Key="AccentScrollThm"   Color="#22D3EE55"/>
        <SolidColorBrush x:Key="AccentListHovBg"   Color="#22D3EE12"/>

        <!-- ═══ STATUS COLORS ═══════════════════════════════════════ -->
        <SolidColorBrush x:Key="Brush_Ok"          Color="#5EEAD4"/>
        <SolidColorBrush x:Key="Brush_Err"         Color="#FB7185"/>
        <SolidColorBrush x:Key="Brush_Info"        Color="#38BDF8"/>
        <SolidColorBrush x:Key="Brush_Warn"        Color="#FBBF24"/>

        <!-- Legacy compatibility aliases (code-behind references) -->
        <SolidColorBrush x:Key="Brush_030B05"      Color="#1A0F00"/>
        <SolidColorBrush x:Key="Brush_8AC8A0"      Color="#C9D7EA"/>
        <SolidColorBrush x:Key="Brush_1A3020"      Color="#585548"/>
        <SolidColorBrush x:Key="Brush_2A4232"      Color="#8A8678"/>
        <SolidColorBrush x:Key="Brush_163025"      Color="#FFB02040"/>
        <SolidColorBrush x:Key="Brush_142018"      Color="#58657A"/>
        <SolidColorBrush x:Key="Brush_2A4030"      Color="#3A382F"/>
        <SolidColorBrush x:Key="Brush_071209"      Color="#10111D"/>
        <SolidColorBrush x:Key="Brush_0A1A0D"      Color="#141923"/>
        <SolidColorBrush x:Key="Brush_08180C"      Color="#141923"/>
        <SolidColorBrush x:Key="Brush_071008"      Color="#07090D"/>
        <SolidColorBrush x:Key="Brush_0F2818"      Color="#FFB02029"/>
        <SolidColorBrush x:Key="Brush_060F08"      Color="#0F131B"/>
        <SolidColorBrush x:Key="Brush_2A0808"      Color="#2A0A0A"/>
        <SolidColorBrush x:Key="Brush_FF5555"      Color="#E26565"/>
        <SolidColorBrush x:Key="Brush_2A4832"      Color="#585548"/>
        <SolidColorBrush x:Key="Brush_2A5038"      Color="#A8C3D8"/>
        <SolidColorBrush x:Key="Brush_3A2020"      Color="#8A8678"/>
        <SolidColorBrush x:Key="Brush_102818"      Color="#FFB0201F"/>
        <SolidColorBrush x:Key="Brush_050D07"      Color="#090A13"/>
        <SolidColorBrush x:Key="Brush_2A6040"      Color="#8A8678"/>

        <!-- ═══ SCROLLBAR ══════════════════════════════════════════ -->
        <Style x:Key="KokoScrollThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{DynamicResource AccentScrollThm}" CornerRadius="2"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource KokoScrollThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ BUTTON: Primary ════════════════════════════════════ -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#22D3EE" Offset="0"/>
                        <GradientStop Color="#8B5CF6" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground"      Value="#F8FBFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="9" Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect Color="#22D3EE" BlurRadius="16" ShadowDepth="0" Opacity="0.18"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#22D3EE" BlurRadius="24" ShadowDepth="0" Opacity="0.45"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ BUTTON: Ghost ═════════════════════════════════════ -->
        <Style x:Key="BtnGhost" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource AccentMuted}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource AccentBgBorder2}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentNavBg}"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource AccentAsstBorder}"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentText}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ BUTTON: Nav (sidebar) ════════════════════════════ -->
        <Style x:Key="BtnNav" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource AccentText}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Height"          Value="42"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="10" Margin="0,2"
                                BorderBrush="Transparent" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"
                                               Margin="12,0,0,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#22D3EE10"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource AccentBgBorder1}"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentTextLight}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnNavActive" TargetType="Button">
            <Setter Property="Foreground"      Value="{DynamicResource AccentTextLight}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Height"          Value="42"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="bd" CornerRadius="10" Margin="0,2"
                                    BorderBrush="{DynamicResource AccentAsstBorder}" BorderThickness="1">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#22D3EE22" Offset="0"/>
                                        <GradientStop Color="#A78BFA24" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect Color="#22D3EE" BlurRadius="18" ShadowDepth="0" Opacity="0.16"/>
                                </Border.Effect>
                                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"
                                                   Margin="16,0,0,0"/>
                            </Border>
                            <Rectangle Width="2" HorizontalAlignment="Left" RadiusX="2" RadiusY="2"
                                       Fill="{DynamicResource AccentBase}" Margin="0,8,0,8">
                                <Rectangle.Effect>
                                    <DropShadowEffect Color="#22D3EE" BlurRadius="10" ShadowDepth="0" Opacity="0.8"/>
                                </Rectangle.Effect>
                            </Rectangle>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Aliases for code-behind Tab_Click compatibility -->
        <Style x:Key="BtnTab"       TargetType="Button" BasedOn="{StaticResource BtnNav}"/>
        <Style x:Key="BtnTabActive" TargetType="Button" BasedOn="{StaticResource BtnNavActive}"/>

        <!-- ═══ BUTTON: Chrome (titlebar) ════════════════════════ -->
        <Style x:Key="ChromeBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource AccentDim}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="32"/>
            <Setter Property="Height"          Value="24"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#22D3EE12"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentTextLight}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ TEXTBOX ══════════════════════════════════════════ -->
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background"      Value="{DynamicResource AccentBgInput}"/>
            <Setter Property="Foreground"      Value="{DynamicResource AccentTextLight}"/>
            <Setter Property="CaretBrush"      Value="{DynamicResource AccentBase}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource AccentBgBorder2}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontFamily"      Value="Segoe UI Variable, Segoe UI"/>
            <Setter Property="Padding"         Value="12,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <Border.Effect>
                                <DropShadowEffect Color="#22D3EE" BlurRadius="10" ShadowDepth="0" Opacity="0"/>
                            </Border.Effect>
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource AccentBase}"/>
                                <Setter TargetName="bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#22D3EE" BlurRadius="16" ShadowDepth="0" Opacity="0.22"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ LISTBOX ══════════════════════════════════════════ -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="Foreground"   Value="{DynamicResource AccentText}"/>
            <Setter Property="Padding"      Value="8,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FFFFFF08"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentNavBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ SETTINGS STYLES (SettingsWindow) ════════════════ -->
        <Style x:Key="SettingsSectionHeader" TargetType="TextBlock">
            <Setter Property="FontFamily"  Value="Consolas"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="Normal"/>
            <Setter Property="Foreground"  Value="{DynamicResource AccentDim}"/>
            <Setter Property="Margin"      Value="0,18,0,8"/>
        </Style>

        <Style x:Key="SettingsLabel" TargetType="TextBlock">
            <Setter Property="FontFamily"  Value="Segoe UI Variable, Segoe UI"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="Foreground"  Value="{DynamicResource AccentMuted}"/>
            <Setter Property="Margin"      Value="0,0,0,4"/>
        </Style>

        <Style x:Key="SettingInput" TargetType="TextBox">
            <Setter Property="Background"      Value="#1B212D"/>
            <Setter Property="Foreground"      Value="{DynamicResource AccentTextLight}"/>
            <Setter Property="CaretBrush"      Value="{DynamicResource AccentBase}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource AccentBgBorder2}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily"      Value="Segoe UI Variable, Segoe UI"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Padding"         Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource AccentBase}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingComboBox" TargetType="ComboBox">
            <Setter Property="Background"      Value="#1B212D"/>
            <Setter Property="Foreground"      Value="{DynamicResource AccentTextLight}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource AccentBgBorder2}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily"      Value="Segoe UI Variable, Segoe UI"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Padding"         Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="toggle"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          Focusable="false"
                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="bd"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4">
                                            <ContentPresenter Margin="8,4"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource AccentBase}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <Border Padding="8,6">
                                    <Grid>
                                        <ContentPresenter Content="{TemplateBinding Text}"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,20,0"/>
                                        <Path x:Name="arrow"
                                              Data="M0,0 L4,4 L8,0 Z"
                                              Fill="{DynamicResource AccentMuted}"
                                              HorizontalAlignment="Right"
                                              VerticalAlignment="Center"
                                              Margin="0,0,8,0"/>
                                    </Grid>
                                </Border>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   PopupAnimation="Slide"
                                   AllowsTransparency="True"
                                   IsOpen="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <Border Background="#141923"
                                        BorderBrush="{DynamicResource AccentBgBorder2}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Margin="0,4,0,0">
                                    <ScrollViewer MaxHeight="300">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
