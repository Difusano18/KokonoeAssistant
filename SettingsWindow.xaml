<Window x:Class="KokonoeAssistant.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Width="400" Height="600"
        Background="#0E0E14" Foreground="#E0E0EE"
        WindowStyle="None" AllowsTransparency="True"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Border BorderBrush="#2A2A35" BorderThickness="1" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="58"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="#0A0A12" CornerRadius="8,8,0,0"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Margin="16,0,8,0">
                    <TextBlock Text="Settings" Foreground="#E0E0EE"
                               FontFamily="Segoe UI Variable, Segoe UI"
                               FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button Content="✕" HorizontalAlignment="Right"
                            Click="Close_Click" Background="Transparent" BorderThickness="0"
                            Foreground="#3A3A4E" FontSize="14" Cursor="Hand"
                            VerticalAlignment="Center" Width="32" Height="32"/>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20,14,20,14">

                    <!-- LLM PROVIDER -->
                    <TextBlock Text="LLM PROVIDER" Style="{StaticResource SettingsSectionHeader}"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <RadioButton x:Name="ProviderLmStudio" Content="LM Studio" GroupName="LlmProvider"
                                   FontFamily="Segoe UI Variable, Segoe UI" FontSize="12"
                                   Foreground="#9090A8" VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <RadioButton x:Name="ProviderClaude" Content="Claude API" GroupName="LlmProvider"
                                   FontFamily="Segoe UI Variable, Segoe UI" FontSize="12"
                                   Foreground="#9090A8" VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <RadioButton x:Name="ProviderOllamaCloud" Content="Ollama Cloud" GroupName="LlmProvider"
                                   FontFamily="Segoe UI Variable, Segoe UI" FontSize="12"
                                   Foreground="#9090A8" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- LM STUDIO SETTINGS -->
                    <Border x:Name="LmStudioSettings" BorderBrush="#1A1A22" BorderThickness="1"
                            CornerRadius="6" Padding="12" Margin="0,0,0,10" Background="#0A0A12">
                        <StackPanel>
                            <TextBlock Text="URL" Style="{StaticResource SettingsLabel}"/>
                            <TextBox x:Name="LmUrlBox" Style="{StaticResource SettingInput}" Margin="0,0,0,10"/>

                            <TextBlock Text="Model" Style="{StaticResource SettingsLabel}"/>
                            <TextBox x:Name="ModelBox" Style="{StaticResource SettingInput}" Margin="0,0,0,4"/>
                        </StackPanel>
                    </Border>

                    <!-- OLLAMA CLOUD SETTINGS -->
                    <Border x:Name="OllamaCloudSettings" BorderBrush="#1A1A22" BorderThickness="1"
                            CornerRadius="6" Padding="12" Margin="0,0,0,10" Background="#0A0A12"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="API Key" Style="{StaticResource SettingsLabel}"/>
                            <TextBox x:Name="OllamaApiKeyBox" Style="{StaticResource SettingInput}"
                                     Margin="0,0,0,10" TextChanged="OllamaApiKey_TextChanged"/>
                            <TextBlock Text="Get your key at https://ollama.com/settings/keys"
                                       Foreground="#3A3A4E" FontFamily="Segoe UI Variable, Segoe UI"
                                       FontSize="10" Margin="0,0,0,8" TextWrapping="Wrap"/>

                            <TextBlock Text="URL" Style="{StaticResource SettingsLabel}"/>
                            <TextBox x:Name="OllamaUrlBox" Style="{StaticResource SettingInput}" Margin="0,0,0,10"/>

                            <TextBlock Text="Model" Style="{StaticResource SettingsLabel}"/>
                            <ComboBox x:Name="OllamaModelBox" Style="{StaticResource SettingComboBox}"
                                      Margin="0,0,0,4" IsEditable="True">
                                <ComboBoxItem Content="gpt-oss:120b-cloud"/>
                                <ComboBoxItem Content="gpt-oss:20b-cloud"/>
                                <ComboBoxItem Content="qwen3-coder:480b-cloud"/>
                                <ComboBoxItem Content="deepseek-v3.1:671b-cloud"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <!-- CLAUDE API SETTINGS -->
                    <Border x:Name="ClaudeSettings" BorderBrush="#1A1A22" BorderThickness="1"
                            CornerRadius="6" Padding="12" Margin="0,0,0,10" Background="#0A0A12"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="API Key" Style="{StaticResource SettingsLabel}"/>
                            <TextBox x:Name="ClaudeApiKeyBox" Style="{StaticResource SettingInput}"
                                     Margin="0,0,0,10" TextChanged="ClaudeApiKey_TextChanged"/>
                            <TextBlock Text="Get your API key at https://console.anthropic.com"
                                       Foreground="#3A3A4E" FontFamily="Segoe UI Variable, Segoe UI"
                                       FontSize="10" Margin="0,0,0,8" TextWrapping="Wrap"/>

                            <TextBlock Text="Model" Style="{StaticResource SettingsLabel}"/>
                            <ComboBox x:Name="ClaudeModelBox" Style="{StaticResource SettingComboBox}"
                                      Margin="0,0,0,4" IsEditable="True">
                                <ComboBoxItem Content="claude-sonnet-4-20250514"/>
                                <ComboBoxItem Content="claude-opus-4-20250514"/>
                                <ComboBoxItem Content="claude-3-7-sonnet-20250219"/>
                                <ComboBoxItem Content="claude-3-5-sonnet-20241022"/>
                                <ComboBoxItem Content="claude-3-haiku-20240307"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <Rectangle Height="1" Fill="#1A1A22" Margin="0,8,0,0"/>

                    <!-- OPENAI (Whisper) -->
                    <TextBlock Text="OPENAI / WHISPER" Style="{StaticResource SettingsSectionHeader}"/>

                    <TextBlock Text="API Key" Style="{StaticResource SettingsLabel}"/>
                    <TextBox x:Name="OpenAiKeyBox" Style="{StaticResource SettingInput}" Margin="0,0,0,8"/>
                    <TextBlock Text="Required for voice input (Whisper STT)" Foreground="#3A3A4E"
                               FontFamily="Segoe UI Variable, Segoe UI" FontSize="10"
                               TextWrapping="Wrap" Margin="0,0,0,6"/>

                    <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                        <CheckBox x:Name="VoiceBox" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Voice input" Foreground="#9090A8"
                                   FontFamily="Segoe UI Variable, Segoe UI"
                                   FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                        <CheckBox x:Name="TtsBox" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Text-to-speech" Foreground="#9090A8"
                                   FontFamily="Segoe UI Variable, Segoe UI"
                                   FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Rectangle Height="1" Fill="#1A1A22" Margin="0,12,0,0"/>

                    <!-- TELEGRAM -->
                    <TextBlock Text="TELEGRAM BOT" Style="{StaticResource SettingsSectionHeader}"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <CheckBox x:Name="TgEnabledBox" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Enable Telegram bot" Foreground="#9090A8"
                                   FontFamily="Segoe UI Variable, Segoe UI"
                                   FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="Bot Token" Style="{StaticResource SettingsLabel}"/>
                    <TextBox x:Name="TgTokenBox" Style="{StaticResource SettingInput}" Margin="0,0,0,10"/>

                    <TextBlock Text="Chat ID" Style="{StaticResource SettingsLabel}"/>
                    <TextBox x:Name="TgChatIdBox" Style="{StaticResource SettingInput}" Margin="0,0,0,10"/>

                    <!-- MTProto User Client -->
                    <Rectangle Height="1" Fill="#1A1A22" Margin="0,4,0,0"/>
                    <TextBlock Text="TELEGRAM USER CLIENT" Style="{StaticResource SettingsSectionHeader}"/>
                    <TextBlock Foreground="#3A3A4E" FontFamily="Segoe UI Variable, Segoe UI"
                               FontSize="10" Margin="0,0,0,10" TextWrapping="Wrap"
                               Text="Full account access. Get api_id and api_hash at my.telegram.org → App API"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <CheckBox x:Name="TgUserEnabledBox" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Enable User Client" Foreground="#9090A8"
                                   FontFamily="Segoe UI Variable, Segoe UI"
                                   FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="API ID" Style="{StaticResource SettingsLabel}"/>
                    <TextBox x:Name="TgApiIdBox" Style="{StaticResource SettingInput}" Margin="0,0,0,10"/>

                    <TextBlock Text="API Hash" Style="{StaticResource SettingsLabel}"/>
                    <TextBox x:Name="TgApiHashBox" Style="{StaticResource SettingInput}" Margin="0,0,0,10"/>

                    <TextBlock Text="Phone number (+38...)" Style="{StaticResource SettingsLabel}"/>
                    <TextBox x:Name="TgPhoneBox" Style="{StaticResource SettingInput}" Margin="0,0,0,10"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <CheckBox x:Name="TgDmOnlyBox" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Foreground="#9090A8" FontFamily="Segoe UI Variable, Segoe UI"
                                   FontSize="12" VerticalAlignment="Center"
                                   Text="Only direct messages (ignore groups/channels)"/>
                    </StackPanel>

                    <Rectangle Height="1" Fill="#1A1A22" Margin="0,12,0,0"/>

                    <!-- SYSTEM -->
                    <TextBlock Text="SYSTEM" Style="{StaticResource SettingsSectionHeader}"/>

                    <TextBlock Text="Vault Path" Style="{StaticResource SettingsLabel}"/>
                    <TextBox x:Name="VaultPathBox" Style="{StaticResource SettingInput}" Margin="0,0,0,10"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <CheckBox x:Name="SpontBox" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Foreground="#9090A8" FontFamily="Segoe UI Variable, Segoe UI"
                                   FontSize="12" VerticalAlignment="Center"
                                   Text="Spontaneous messages"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <CheckBox x:Name="TrayBox" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Minimize to tray" Foreground="#9090A8"
                                   FontFamily="Segoe UI Variable, Segoe UI"
                                   FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Rectangle Height="1" Fill="#1A1A22" Margin="0,12,0,0"/>

                    <!-- THEME -->
                    <TextBlock Text="ACCENT COLOR" Style="{StaticResource SettingsSectionHeader}"/>

                    <WrapPanel Margin="0,0,0,10">
                        <Button Background="#6366F1" Width="26" Height="26" Margin="0,0,6,0" Cursor="Hand"
                                Click="ColorSwatch_Click" Tag="#6366F1" ToolTip="Indigo" BorderThickness="0"/>
                        <Button Background="#22C55E" Width="26" Height="26" Margin="0,0,6,0" Cursor="Hand"
                                Click="ColorSwatch_Click" Tag="#22C55E" ToolTip="Emerald" BorderThickness="0"/>
                        <Button Background="#F59E0B" Width="26" Height="26" Margin="0,0,6,0" Cursor="Hand"
                                Click="ColorSwatch_Click" Tag="#F59E0B" ToolTip="Amber" BorderThickness="0"/>
                        <Button Background="#EF4444" Width="26" Height="26" Margin="0,0,6,0" Cursor="Hand"
                                Click="ColorSwatch_Click" Tag="#EF4444" ToolTip="Red" BorderThickness="0"/>
                        <Button Background="#22D3EE" Width="26" Height="26" Margin="0,0,6,0" Cursor="Hand"
                                Click="ColorSwatch_Click" Tag="#22D3EE" ToolTip="Cyan" BorderThickness="0"/>
                        <Button Background="#E879F9" Width="26" Height="26" Margin="0,0,6,0" Cursor="Hand"
                                Click="ColorSwatch_Click" Tag="#E879F9" ToolTip="Fuchsia" BorderThickness="0"/>
                        <Button Background="#FFFFFF" Width="26" Height="26" Margin="0,0,12,0" Cursor="Hand"
                                Click="ColorSwatch_Click" Tag="#FFFFFF" ToolTip="White" BorderThickness="0"/>
                        <Button Width="26" Height="26" Margin="0,0,14,0" Cursor="Hand"
                                Click="CustomColorSwatch_Click" ToolTip="Custom..." BorderThickness="0">
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FF0000" Offset="0.0"/>
                                    <GradientStop Color="#00FF00" Offset="0.33"/>
                                    <GradientStop Color="#0000FF" Offset="0.66"/>
                                    <GradientStop Color="#FF00FF" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Button.Background>
                        </Button>
                        <TextBlock Text="HEX:" Foreground="#6B6B80"
                                   FontFamily="Segoe UI Variable, Segoe UI" FontSize="11"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox x:Name="MatrixColorBox" Style="{StaticResource SettingInput}"
                                 Width="80" Padding="6,4" VerticalAlignment="Center"/>
                    </WrapPanel>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#0A0A12" CornerRadius="0,0,8,8"
                    BorderBrush="#1A1A22" BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Margin="16,0">
                    <Button Content="Cancel" Click="Cancel_Click"
                            Background="Transparent" BorderBrush="#2A2A35" BorderThickness="1"
                            Foreground="#6B6B80" FontFamily="Segoe UI Variable, Segoe UI"
                            FontSize="12" Cursor="Hand" Padding="16,8" Margin="0,0,8,0"/>
                    <Button Content="Save" Click="Save_Click"
                            Background="#6366F1" BorderThickness="0"
                            Foreground="White" FontFamily="Segoe UI Variable, Segoe UI"
                            FontSize="12" FontWeight="SemiBold" Cursor="Hand" Padding="20,8"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
