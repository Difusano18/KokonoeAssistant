<Window x:Class="KokonoeAssistant.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Width="420" Height="720"
        Background="{DynamicResource AccentBgMain}" Foreground="{DynamicResource AccentTextLight}"
        WindowStyle="None" AllowsTransparency="True"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Border BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="1" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="58"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="{DynamicResource AccentBgDarker}" CornerRadius="8,8,0,0"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Margin="16,0,8,0">
                    <TextBlock Text="Settings" Foreground="{DynamicResource AccentTextLight}"
                               FontFamily="Segoe UI Variable, Segoe UI"
                               FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button Content="✕" HorizontalAlignment="Right"
                            Click="Close_Click" Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource AccentDim}" FontSize="14" Cursor="Hand"
                            VerticalAlignment="Center" Width="32" Height="32"/>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20,14,20,14">

                    <!-- LLM PROVIDER -->
                    <TextBlock Text="LLM PROVIDER" Style="{StaticResource SettingsSectionHeader}"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <RadioButton x:Name="ProviderLmStudio" Content="LM Studio" GroupName="LlmProvider"
                                   FontFamily="Segoe UI Variable, Segoe UI" FontSize="12"
                                   Foreground="{DynamicResource AccentMuted}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <RadioButton x:Name="ProviderClaude" Content="Claude API" GroupName="LlmProvider"
                                   FontFamily="Segoe UI Variable, Segoe UI" FontSize="12"
                                   Foreground="{DynamicResource AccentMuted}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <RadioButton x:Name="ProviderOllamaCloud" Content="Ollama Cloud" GroupName="LlmProvider"
                                   FontFamily="Segoe UI Variable, Segoe UI" FontSize="12"
                                   Foreground="{DynamicResource AccentMuted}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- LM STUDIO SETTINGS -->
                    <Border x:Name="LmStudioSettings" BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="1"
                            CornerRadius="6" Padding="12" Margin="0,0,0,10" Background="{DynamicResource AccentBgDarker}">
                        <StackPanel>
                            <TextBlock Text="URL" Style="{StaticResource SettingsLabel}"/>
                            <TextBox x:Name="LmUrlBox" Style="{StaticResource SettingInput}" Margin="0,0,0,10"/>

                            <TextBlock Text="Model" Style="{StaticResource SettingsLabel}"/>
                            <TextBox x:Name="ModelBox" Style="{StaticResource SettingInput}" Margin="0,0,0,4"/>
                        </StackPanel>
                    </Border>

                    <!-- OLLAMA CLOUD SETTINGS -->
                    <Border x:Name="OllamaCloudSettings" BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="1"
                            CornerRadius="6" Padding="12" Margin="0,0,0,10" Background="{DynamicResource AccentBgDarker}"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="API Key" Style="{StaticResource SettingsLabel}"/>
                            <TextBox x:Name="OllamaApiKeyBox" Style="{StaticResource SettingInput}"
                                     Margin="0,0,0,10" TextChanged="OllamaApiKey_TextChanged"/>
                            <TextBlock Text="Get your key at https://ollama.com/settings/keys"
                                       Foreground="{DynamicResource AccentDim}" FontFamily="Segoe UI Variable, Segoe UI"
                                       FontSize="10" Margin="0,0,0,8" TextWrapping="Wrap"/>

                            <TextBlock Text="URL" Style="{StaticResource SettingsLabel}"/>
                            <TextBox x:Name="OllamaUrlBox" Style="{StaticResource SettingInput}" Margin="0,0,0,10"/>

                            <TextBlock Text="Model" Style="{StaticResource SettingsLabel}"/>
                            <ComboBox x:Name="OllamaModelBox" Style="{StaticResource SettingComboBox}"
                                      Margin="0,0,0,4" IsEditable="True">
                                <ComboBoxItem Content="gemma4:31b-cloud"/>
                                <ComboBoxItem Content="gpt-oss:120b-cloud"/>
                                <ComboBoxItem Content="gpt-oss:20b-cloud"/>
                                <ComboBoxItem Content="qwen3-coder:480b-cloud"/>
                                <ComboBoxItem Content="deepseek-v3.1:671b-cloud"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <!-- CLAUDE API SETTINGS -->
                    <Border x:Name="ClaudeSettings" BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="1"
                            CornerRadius="6" Padding="12" Margin="0,0,0,10" Background="{DynamicResource AccentBgDarker}"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="API Key" Style="{StaticResource SettingsLabel}"/>
                            <TextBox x:Name="ClaudeApiKeyBox" Style="{StaticResource SettingInput}"
                                     Margin="0,0,0,10" TextChanged="ClaudeApiKey_TextChanged"/>
                            <TextBlock Text="Get your API key at https://console.anthropic.com"
                                       Foreground="{DynamicResource AccentDim}" FontFamily="Segoe UI Variable, Segoe UI"
                                       FontSize="10" Margin="0,0,0,8" TextWrapping="Wrap"/>

                            <TextBlock Text="Model" Style="{StaticResource SettingsLabel}"/>
                            <ComboBox x:Name="ClaudeModelBox" Style="{StaticResource SettingComboBox}"
                                      Margin="0,0,0,4" IsEditable="True">
                                <ComboBoxItem Content="claude-sonnet-4-20250514"/>
                                <ComboBoxItem Content="claude-opus-4-20250514"/>
                                <ComboBoxItem Content="claude-3-7-sonnet-20250219"/>
                                <ComboBoxItem Content="claude-3-5-sonnet-20241022"/>
                                <ComboBoxItem Content="claude-3-haiku-20240307"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <Rectangle Height="1" Fill="{DynamicResource AccentBgBorder2}" Margin="0,8,0,0"/>

                    <!-- OPENAI (Whisper) -->
                    <TextBlock Text="OPENAI / WHISPER" Style="{StaticResource SettingsSectionHeader}"/>

                    <TextBlock Text="API Key" Style="{StaticResource SettingsLabel}"/>
                    <TextBox x:Name="OpenAiKeyBox" Style="{StaticResource SettingInput}" Margin="0,0,0,8"/>
                    <TextBlock Text="Required for voice input (Whisper STT)" Foreground="{DynamicResource AccentDim}"
                               FontFamily="Segoe UI Variable, Segoe UI" FontSize="10"
                               TextWrapping="Wrap" Margin="0,0,0,6"/>

                    <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                        <CheckBox x:Name="VoiceBox" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Voice input" Foreground="{DynamicResource AccentMuted}"
                                   FontFamily="Segoe UI Variable, Segoe UI"
                                   FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                        <CheckBox x:Name="TtsBox" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Text-to-speech" Foreground="{DynamicResource AccentMuted}"
                                   FontFamily="Segoe UI Variable, Segoe UI"
                                   FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Rectangle Height="1" Fill="{DynamicResource AccentBgBorder2}" Margin="0,12,0,0"/>

                    <!-- WEAR BRIDGE -->
                    <TextBlock Text="WEAR BRIDGE" Style="{StaticResource SettingsSectionHeader}"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <CheckBox x:Name="WearBridgeEnabledBox" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Enable desktop bridge" Foreground="{DynamicResource AccentMuted}"
                                   FontFamily="Segoe UI Variable, Segoe UI"
                                   FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <CheckBox x:Name="WearBridgePromptBox" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Include wearable context in prompts" Foreground="{DynamicResource AccentMuted}"
                                   FontFamily="Segoe UI Variable, Segoe UI"
                                   FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="Port" Style="{StaticResource SettingsLabel}"/>
                    <TextBox x:Name="WearBridgePortBox" Style="{StaticResource SettingInput}" Margin="0,0,0,10"/>

                    <TextBlock Text="Fallback notebook URLs" Style="{StaticResource SettingsLabel}"/>
                    <TextBox x:Name="WearBridgeExternalUrlsBox" Style="{StaticResource SettingInput}"
                             TextWrapping="Wrap" AcceptsReturn="True" MinHeight="48"
                             Margin="0,0,0,10"/>
                    <TextBlock Text="One per line, for example http://192.168.1.10:8787 and http://192.168.0.10:8787"
                               Foreground="{DynamicResource AccentDim}" FontFamily="Segoe UI Variable, Segoe UI"
                               FontSize="10" Margin="0,0,0,8" TextWrapping="Wrap"/>

                    <Border BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="1"
                            CornerRadius="6" Padding="12" Margin="0,0,0,10" Background="{DynamicResource AccentBgDarker}">
                        <StackPanel>
                            <TextBlock x:Name="WearBridgeStatusText" Foreground="{DynamicResource AccentTextLight}"
                                       FontFamily="Segoe UI Variable, Segoe UI"
                                       FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap"/>
                            <TextBlock x:Name="WearBridgeLinkText" Foreground="{DynamicResource Brush_Warn}"
                                       FontFamily="Segoe UI Variable, Segoe UI"
                                       FontSize="18" FontWeight="Bold" TextWrapping="Wrap"
                                       Margin="0,4,0,8"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="88"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Server" Style="{StaticResource SettingsLabel}" Margin="0,0,8,4"/>
                                <TextBlock x:Name="WearBridgeServerText" Grid.Row="0" Grid.Column="1" Foreground="{DynamicResource AccentMuted}"
                                           FontFamily="Segoe UI Variable, Segoe UI" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,4"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Link" Style="{StaticResource SettingsLabel}" Margin="0,0,8,4"/>
                                <TextBlock x:Name="WearBridgeLinkDetailText" Grid.Row="1" Grid.Column="1" Foreground="{DynamicResource AccentMuted}"
                                           FontFamily="Segoe UI Variable, Segoe UI" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,4"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Traffic" Style="{StaticResource SettingsLabel}" Margin="0,0,8,4"/>
                                <TextBlock x:Name="WearBridgeTrafficText" Grid.Row="2" Grid.Column="1" Foreground="{DynamicResource AccentMuted}"
                                           FontFamily="Segoe UI Variable, Segoe UI" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,4"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Commands" Style="{StaticResource SettingsLabel}" Margin="0,0,8,4"/>
                                <TextBlock x:Name="WearBridgeCommandText" Grid.Row="3" Grid.Column="1" Foreground="{DynamicResource AccentMuted}"
                                           FontFamily="Segoe UI Variable, Segoe UI" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,4"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Endpoint" Style="{StaticResource SettingsLabel}" Margin="0,0,8,4"/>
                                <TextBlock x:Name="WearBridgeEndpointText" Grid.Row="4" Grid.Column="1" Foreground="{DynamicResource AccentMuted}"
                                           FontFamily="Segoe UI Variable, Segoe UI" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,4"/>

                                <TextBlock Grid.Row="5" Grid.Column="0" Text="Samples" Style="{StaticResource SettingsLabel}" Margin="0,0,8,4"/>
                                <TextBlock x:Name="WearBridgeSampleIdsText" Grid.Row="5" Grid.Column="1" Foreground="{DynamicResource AccentMuted}"
                                           FontFamily="Segoe UI Variable, Segoe UI" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,4"/>
                            </Grid>
                            <TextBlock Text="Bridge token" Style="{StaticResource SettingsLabel}" Margin="0,10,0,2"/>
                            <TextBox x:Name="WearBridgeTokenBox" Style="{StaticResource SettingInput}"
                                     IsReadOnly="True" Margin="0,0,0,8"/>
                            <TextBlock Text="LAN URLs" Style="{StaticResource SettingsLabel}"/>
                            <TextBox x:Name="WearBridgeUrlsBox" Style="{StaticResource SettingInput}"
                                     IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True"
                                     MinHeight="42" Margin="0,0,0,8"/>
                            <TextBlock x:Name="WearBridgeTelemetryText" Foreground="{DynamicResource AccentMuted}"
                                       FontFamily="Segoe UI Variable, Segoe UI"
                                       FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"/>
                            <TextBlock x:Name="WearBridgeLastErrorText" Foreground="{DynamicResource Brush_Warn}"
                                       FontFamily="Segoe UI Variable, Segoe UI"
                                       FontSize="11" TextWrapping="Wrap"/>

                            <WrapPanel Margin="0,10,0,0">
                                <Button Content="Start" Click="WearBridgeStart_Click"
                                        Style="{StaticResource BtnGhost}"
                                        Foreground="{DynamicResource AccentTextLight}" FontFamily="Segoe UI Variable, Segoe UI"
                                        FontSize="12" Cursor="Hand" Padding="12,6" Margin="0,0,6,6"/>
                                <Button Content="Stop" Click="WearBridgeStop_Click"
                                        Style="{StaticResource BtnGhost}"
                                        Foreground="{DynamicResource AccentTextLight}" FontFamily="Segoe UI Variable, Segoe UI"
                                        FontSize="12" Cursor="Hand" Padding="12,6" Margin="0,0,6,6"/>
                                <Button Content="Copy Token" Click="WearBridgeCopyToken_Click"
                                        Style="{StaticResource BtnGhost}"
                                        Foreground="{DynamicResource AccentTextLight}" FontFamily="Segoe UI Variable, Segoe UI"
                                        FontSize="12" Cursor="Hand" Padding="12,6" Margin="0,0,6,6"/>
                                <Button Content="Copy Diagnostics" Click="WearBridgeCopyDiagnostics_Click"
                                        Style="{StaticResource BtnGhost}"
                                        Foreground="{DynamicResource AccentTextLight}" FontFamily="Segoe UI Variable, Segoe UI"
                                        FontSize="12" Cursor="Hand" Padding="12,6" Margin="0,0,6,6"/>
                                <Button Content="Refresh Pair" Click="WearBridgeRefreshPair_Click"
                                        Style="{StaticResource BtnGhost}"
                                        Foreground="{DynamicResource AccentTextLight}" FontFamily="Segoe UI Variable, Segoe UI"
                                        FontSize="12" Cursor="Hand" Padding="12,6" Margin="0,0,6,6"/>
                                <Button Content="Restart Watch" Click="WearBridgeRestartWatch_Click"
                                        Style="{StaticResource BtnGhost}"
                                        Foreground="{DynamicResource AccentTextLight}" FontFamily="Segoe UI Variable, Segoe UI"
                                        FontSize="12" Cursor="Hand" Padding="12,6" Margin="0,0,6,6"/>
                                <Button Content="Clear Queue" Click="WearBridgeClearQueue_Click"
                                        Style="{StaticResource BtnGhost}"
                                        Foreground="{DynamicResource AccentTextLight}" FontFamily="Segoe UI Variable, Segoe UI"
                                        FontSize="12" Cursor="Hand" Padding="12,6" Margin="0,0,6,6"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Rectangle Height="1" Fill="{DynamicResource AccentBgBorder2}" Margin="0,12,0,0"/>

                    <!-- TELEGRAM -->
                    <TextBlock Text="TELEGRAM BOT" Style="{StaticResource SettingsSectionHeader}"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <CheckBox x:Name="TgEnabledBox" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Enable Telegram bot" Foreground="{DynamicResource AccentMuted}"
                                   FontFamily="Segoe UI Variable, Segoe UI"
                                   FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="Bot Token" Style="{StaticResource SettingsLabel}"/>
                    <TextBox x:Name="TgTokenBox" Style="{StaticResource SettingInput}" Margin="0,0,0,10"/>

                    <TextBlock Text="Chat ID" Style="{StaticResource SettingsLabel}"/>
                    <TextBox x:Name="TgChatIdBox" Style="{StaticResource SettingInput}" Margin="0,0,0,10"/>

                    <!-- MTProto User Client -->
                    <Rectangle Height="1" Fill="{DynamicResource AccentBgBorder2}" Margin="0,4,0,0"/>
                    <TextBlock Text="TELEGRAM USER CLIENT" Style="{StaticResource SettingsSectionHeader}"/>
                    <TextBlock Foreground="{DynamicResource AccentDim}" FontFamily="Segoe UI Variable, Segoe UI"
                               FontSize="10" Margin="0,0,0,10" TextWrapping="Wrap"
                               Text="Full account access. Get api_id and api_hash at my.telegram.org → App API"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <CheckBox x:Name="TgUserEnabledBox" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Enable User Client" Foreground="{DynamicResource AccentMuted}"
                                   FontFamily="Segoe UI Variable, Segoe UI"
                                   FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="API ID" Style="{StaticResource SettingsLabel}"/>
                    <TextBox x:Name="TgApiIdBox" Style="{StaticResource SettingInput}" Margin="0,0,0,10"/>

                    <TextBlock Text="API Hash" Style="{StaticResource SettingsLabel}"/>
                    <TextBox x:Name="TgApiHashBox" Style="{StaticResource SettingInput}" Margin="0,0,0,10"/>

                    <TextBlock Text="Phone number (+38...)" Style="{StaticResource SettingsLabel}"/>
                    <TextBox x:Name="TgPhoneBox" Style="{StaticResource SettingInput}" Margin="0,0,0,10"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <CheckBox x:Name="TgDmOnlyBox" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Foreground="{DynamicResource AccentMuted}" FontFamily="Segoe UI Variable, Segoe UI"
                                   FontSize="12" VerticalAlignment="Center"
                                   Text="Only direct messages (ignore groups/channels)"/>
                    </StackPanel>

                    <Rectangle Height="1" Fill="{DynamicResource AccentBgBorder2}" Margin="0,12,0,0"/>

                    <!-- SYSTEM -->
                    <TextBlock Text="SYSTEM" Style="{StaticResource SettingsSectionHeader}"/>

                    <TextBlock Text="Vault Path" Style="{StaticResource SettingsLabel}"/>
                    <TextBox x:Name="VaultPathBox" Style="{StaticResource SettingInput}" Margin="0,0,0,10"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <CheckBox x:Name="SpontBox" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Foreground="{DynamicResource AccentMuted}" FontFamily="Segoe UI Variable, Segoe UI"
                                   FontSize="12" VerticalAlignment="Center"
                                   Text="Spontaneous messages"/>
                    </StackPanel>

                    <TextBlock Text="Spontaneous interval (minutes)" Style="{StaticResource SettingsLabel}"/>
                    <TextBox x:Name="SpontIntervalBox" Style="{StaticResource SettingInput}" Margin="0,0,0,8"/>

                    <TextBlock Text="Proactive autonomy level (0-3)" Style="{StaticResource SettingsLabel}"/>
                    <TextBox x:Name="ProactiveLevelBox" Style="{StaticResource SettingInput}" Margin="0,0,0,10"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <CheckBox x:Name="TrayBox" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Minimize to tray" Foreground="{DynamicResource AccentMuted}"
                                   FontFamily="Segoe UI Variable, Segoe UI"
                                   FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Rectangle Height="1" Fill="{DynamicResource AccentBgBorder2}" Margin="0,12,0,0"/>

                    <!-- THEME -->
                    <TextBlock Text="ACCENT COLOR" Style="{StaticResource SettingsSectionHeader}"/>

                    <WrapPanel Margin="0,0,0,10">
                        <Button Background="{DynamicResource RgbBlueBrush}" Width="26" Height="26" Margin="0,0,6,0" Cursor="Hand"
                                Click="ColorSwatch_Click" Tag="#6366F1" ToolTip="Indigo" BorderThickness="0"/>
                        <Button Background="{DynamicResource RgbGreenBrush}" Width="26" Height="26" Margin="0,0,6,0" Cursor="Hand"
                                Click="ColorSwatch_Click" Tag="#22C55E" ToolTip="Emerald" BorderThickness="0"/>
                        <Button Background="{DynamicResource Brush_Warn}" Width="26" Height="26" Margin="0,0,6,0" Cursor="Hand"
                                Click="ColorSwatch_Click" Tag="#F59E0B" ToolTip="Amber" BorderThickness="0"/>
                        <Button Background="{DynamicResource RgbRedBrush}" Width="26" Height="26" Margin="0,0,6,0" Cursor="Hand"
                                Click="ColorSwatch_Click" Tag="#EF4444" ToolTip="Red" BorderThickness="0"/>
                        <Button Background="{DynamicResource AccentBase}" Width="26" Height="26" Margin="0,0,6,0" Cursor="Hand"
                                Click="ColorSwatch_Click" Tag="#22D3EE" ToolTip="Cyan" BorderThickness="0"/>
                        <Button Background="{DynamicResource AccentDark}" Width="26" Height="26" Margin="0,0,6,0" Cursor="Hand"
                                Click="ColorSwatch_Click" Tag="#E879F9" ToolTip="Fuchsia" BorderThickness="0"/>
                        <Button Background="{DynamicResource AccentTextLight}" Width="26" Height="26" Margin="0,0,12,0" Cursor="Hand"
                                Click="ColorSwatch_Click" Tag="#FFFFFF" ToolTip="White" BorderThickness="0"/>
                        <Button Width="26" Height="26" Margin="0,0,14,0" Cursor="Hand"
                                Click="CustomColorSwatch_Click" ToolTip="Custom..." BorderThickness="0">
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FF0000" Offset="0.0"/>
                                    <GradientStop Color="#00FF00" Offset="0.33"/>
                                    <GradientStop Color="#0000FF" Offset="0.66"/>
                                    <GradientStop Color="#FF00FF" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Button.Background>
                        </Button>
                        <TextBlock Text="HEX:" Foreground="{DynamicResource AccentDim}"
                                   FontFamily="Segoe UI Variable, Segoe UI" FontSize="11"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox x:Name="MatrixColorBox" Style="{StaticResource SettingInput}"
                                 Width="80" Padding="6,4" VerticalAlignment="Center"/>
                    </WrapPanel>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="{DynamicResource AccentBgDarker}" CornerRadius="0,0,8,8"
                    BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Margin="16,0">
                    <Button Content="Cancel" Click="Cancel_Click"
                            Background="Transparent" BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="1"
                            Foreground="{DynamicResource AccentDim}" FontFamily="Segoe UI Variable, Segoe UI"
                            FontSize="12" Cursor="Hand" Padding="16,8" Margin="0,0,8,0"/>
                    <Button Content="Save" Click="Save_Click"
                            Background="{DynamicResource RgbBlueBrush}" BorderThickness="0"
                            Foreground="{DynamicResource AccentTextLight}" FontFamily="Segoe UI Variable, Segoe UI"
                            FontSize="12" FontWeight="SemiBold" Cursor="Hand" Padding="20,8"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
