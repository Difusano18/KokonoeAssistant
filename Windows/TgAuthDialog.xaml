<Window x:Class="KokonoeAssistant.TgAuthDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Telegram Auth" Width="380" Height="200"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" WindowStyle="ToolWindow"
        Background="{DynamicResource AccentBgMain}">

    <Border Background="{DynamicResource KokoWindowBackground}"
            BorderBrush="{DynamicResource AccentBgBorder2}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="24">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="PromptText" Grid.Row="0"
                   Text="Введи код:" FontSize="13"
                   Foreground="{DynamicResource AccentBase}" FontFamily="Consolas"
                   TextWrapping="Wrap"/>

        <TextBox x:Name="InputBox" Grid.Row="2"
                 FontSize="14" FontFamily="Consolas"
                 Background="{DynamicResource AccentBgInput}" Foreground="{DynamicResource AccentTextLight}"
                 BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="1"
                 Padding="8,6" Height="36"
                 KeyDown="InputBox_KeyDown"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="OK" Width="80" Height="32"
                    Style="{StaticResource BtnPrimary}" FontFamily="Consolas"
                    Click="Ok_Click"/>
        </StackPanel>
    </Grid>
    </Border>
</Window>
