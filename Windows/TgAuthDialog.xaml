<Window x:Class="KokonoeAssistant.TgAuthDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Telegram Auth" Width="380" Height="200"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" WindowStyle="ToolWindow"
        Background="#0D1A10">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="PromptText" Grid.Row="0"
                   Text="Введи код:" FontSize="13"
                   Foreground="#8AC8A0" FontFamily="Consolas"
                   TextWrapping="Wrap"/>

        <TextBox x:Name="InputBox" Grid.Row="2"
                 FontSize="14" FontFamily="Consolas"
                 Background="#1A2E1E" Foreground="#C8F0D8"
                 BorderBrush="#2A5C3A" BorderThickness="1"
                 Padding="8,6" Height="36"
                 KeyDown="InputBox_KeyDown"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="OK" Width="80" Height="32"
                    Background="#2A7A4A" Foreground="#C8F0D8"
                    BorderThickness="0" FontFamily="Consolas"
                    Click="Ok_Click"/>
        </StackPanel>
    </Grid>
</Window>
