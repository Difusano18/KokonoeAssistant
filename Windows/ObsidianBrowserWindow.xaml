<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="KokonoeAssistant.Windows.ObsidianBrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Obsidian Vault Browser" Height="800" Width="500"
        MinHeight="600" MinWidth="400"
        Background="{DynamicResource AccentBgMain}"
        Foreground="{DynamicResource AccentText}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <Style x:Key="VaultBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentText}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentNavBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="1" CornerRadius="8" Background="{DynamicResource KokoWindowBackground}">
        <Grid Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{DynamicResource KokoHeaderBrush}" BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                    <TextBlock Text="Vault Browser" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource AccentTextLight}" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- File Tree -->
            <Border Grid.Row="1" Background="Transparent" Margin="0">
                <TreeView x:Name="FileTree" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource AccentText}" Margin="5"/>
            </Border>

            <!-- File Preview -->
            <Border Grid.Row="2" Background="{DynamicResource KokoFooterBrush}" BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="0,1,0,0" Padding="10">
                <TextBox x:Name="PreviewBox" Background="{DynamicResource AccentBgDarker}" Foreground="{DynamicResource AccentText}" BorderThickness="0"
                         IsReadOnly="True" TextWrapping="Wrap" Height="100" Margin="0"/>
            </Border>
        </Grid>
    </Border>
</Window>
