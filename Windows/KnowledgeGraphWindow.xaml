<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="KokonoeAssistant.Windows.KnowledgeGraphWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Knowledge Graph" Height="800" Width="900"
        MinHeight="600" MinWidth="700"
        Background="#0B0B18"
        Foreground="#E0E0E0"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip">

    <Border BorderBrush="#1A1A2E" BorderThickness="1" CornerRadius="8">
        <Grid Background="#0B0B18">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#12121F" BorderBrush="#1A1A2E" BorderThickness="0,0,0,1">
                <Grid VerticalAlignment="Center" Margin="10,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="🧠 Knowledge Graph" FontSize="14" FontWeight="Bold" Foreground="#FF6B35" VerticalAlignment="Center"/>
                    <Button Grid.Column="2" Content="🔄 Refresh" Background="#7777BB" Foreground="White"
                            Margin="0,0,10,0" Padding="10,6" Click="RefreshButton_Click"/>
                    <Button Grid.Column="3" Content="📤 Export DOT" Background="#FF6B35" Foreground="White"
                            Padding="10,6" Click="ExportButton_Click"/>
                </Grid>
            </Border>

            <!-- Graph Canvas -->
            <Canvas x:Name="GraphCanvas" Grid.Row="1" Background="#080810"/>

            <!-- Legend -->
            <Border Grid.Row="2" Background="#12121F" BorderBrush="#1A1A2E" BorderThickness="0,1,0,0" Padding="10">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Legend: " Foreground="#BCCCDC" Margin="0,0,10,0"/>
                    <Ellipse Fill="#FF6B35" Width="8" Height="8" Margin="0,0,5,0"/>
                    <TextBlock Text="Topics" Foreground="#BCCCDC" Margin="0,0,15,0"/>
                    <Ellipse Fill="#00CCFF" Width="8" Height="8" Margin="0,0,5,0"/>
                    <TextBlock Text="Notes" Foreground="#BCCCDC" Margin="0,0,15,0"/>
                    <Ellipse Fill="#00CC99" Width="8" Height="8" Margin="0,0,5,0"/>
                    <TextBlock Text="Facts" Foreground="#BCCCDC"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
