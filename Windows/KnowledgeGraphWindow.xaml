<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="KokonoeAssistant.Windows.KnowledgeGraphWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Knowledge Graph" Height="800" Width="900"
        MinHeight="600" MinWidth="700"
        Background="{DynamicResource AccentBgMain}"
        Foreground="{DynamicResource AccentText}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip">

    <Border BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="1" CornerRadius="8" Background="{DynamicResource KokoWindowBackground}">
        <Grid Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{DynamicResource KokoHeaderBrush}" BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="0,0,0,1">
                <Grid VerticalAlignment="Center" Margin="14,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Knowledge Graph" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource AccentTextLight}" VerticalAlignment="Center"/>
                    <Button Grid.Column="2" Content="Refresh" Style="{StaticResource BtnGhost}" Margin="0,0,10,0" Padding="12,6" Click="RefreshButton_Click"/>
                    <Button Grid.Column="3" Content="Export DOT" Style="{StaticResource BtnPrimary}" Padding="12,6" Click="ExportButton_Click"/>
                </Grid>
            </Border>

            <!-- Graph Canvas -->
            <Canvas x:Name="GraphCanvas" Grid.Row="1" Background="{DynamicResource AccentBgDarker}"/>

            <!-- Legend -->
            <Border Grid.Row="2" Background="{DynamicResource KokoFooterBrush}" BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="0,1,0,0" Padding="12,10">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Legend: " Foreground="{DynamicResource AccentText}" Margin="0,0,10,0"/>
                    <Ellipse Fill="{DynamicResource AccentBase}" Width="8" Height="8" Margin="0,0,5,0"/>
                    <TextBlock Text="Topics" Foreground="{DynamicResource AccentText}" Margin="0,0,15,0"/>
                    <Ellipse Fill="{DynamicResource RgbBlueBrush}" Width="8" Height="8" Margin="0,0,5,0"/>
                    <TextBlock Text="Notes" Foreground="{DynamicResource AccentText}" Margin="0,0,15,0"/>
                    <Ellipse Fill="{DynamicResource RgbGreenBrush}" Width="8" Height="8" Margin="0,0,5,0"/>
                    <TextBlock Text="Facts" Foreground="{DynamicResource AccentText}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
