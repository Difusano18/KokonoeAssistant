<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="KokonoeAssistant.Windows.MediaViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kokonoe - Visual Monitoring" 
        Width="1200" 
        Height="800"
        Background="{DynamicResource AccentBgMain}"
        Foreground="{DynamicResource AccentText}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">
    
    <Grid Background="{DynamicResource KokoWindowBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource KokoHeaderBrush}" BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                <TextBlock x:Name="TitleStatus" Text="Visual Monitoring" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource AccentTextLight}" VerticalAlignment="Center"/>
                <TextBlock x:Name="StatusText" FontSize="12" Foreground="{DynamicResource AccentText}" Margin="30,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" Background="{DynamicResource AccentBgMain}" Margin="10" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="MediaGrid" Background="Transparent"/>
        </ScrollViewer>

        <Border Grid.Row="2" Background="{DynamicResource KokoFooterBrush}" BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" Margin="15,0" VerticalAlignment="Center">
                <Button x:Name="RefreshButton" Content="Refresh" Style="{StaticResource BtnPrimary}" Padding="12,8" Click="RefreshButton_Click" FontSize="12" MinWidth="100"/>
                <Button x:Name="ExportButton" Content="Export" Style="{StaticResource BtnGhost}" Padding="12,8" Margin="10,0,0,0" Click="ExportButton_Click" FontSize="12" MinWidth="100"/>
                <TextBlock x:Name="FrameCountText" Text="Frames: 0/12" FontSize="12" Foreground="{DynamicResource AccentText}" Margin="30,0,0,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="StatusInfoText" FontSize="11" Foreground="{DynamicResource AccentMuted}" Margin="Auto,0,0,0" VerticalAlignment="Center"/>
                <Button x:Name="CloseButton" Content="Close" Style="{StaticResource BtnGhost}" Padding="12,8" Margin="15,0,0,0" Click="CloseButton_Click" FontSize="12" MinWidth="64"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
