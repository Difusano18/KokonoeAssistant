<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="KokonoeAssistant.Windows.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kokonoe Chat" Height="900" Width="1400"
        MinHeight="600" MinWidth="800"
        Background="{DynamicResource AccentBgMain}"
        Foreground="{DynamicResource AccentText}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentPrimary}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBgMain}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentPale}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentAmberLine}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentText}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBgBorder2}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentNavBg}"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentTextLight}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentAsstBorder}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource AccentBgInput}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentTextLight}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBgBorder2}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Padding="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBase}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{DynamicResource AccentBgMain}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="100"/>
        </Grid.RowDefinitions>

            <!-- Message List Area - Full Width -->
            <ListBox x:Name="MessageList" Grid.Row="0" Background="Transparent" BorderThickness="0" Margin="14,12,230,12">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="10,5" Padding="13,11" BorderThickness="1" BorderBrush="{DynamicResource AccentBgBorder2}" CornerRadius="7" Background="{DynamicResource KokoCardBrush}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                        <TextBlock Text="{Binding Role}" FontSize="11" Foreground="{DynamicResource AccentBase}" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding Timestamp, StringFormat=HH:mm:ss}" FontSize="10" Foreground="{DynamicResource AccentDim}" Margin="10,0,0,0"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Content}" TextWrapping="Wrap" Foreground="{DynamicResource AccentText}" FontSize="12"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            <!-- Pinned Messages Sidebar -->
            <Border Grid.Row="0" Background="{DynamicResource KokoSidebarBrush}" BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="1,0,0,0" Margin="0" Width="220" HorizontalAlignment="Right">
                <StackPanel>
                    <TextBlock Text="📌 Pinned" FontSize="12" Foreground="{DynamicResource AccentBase}" FontWeight="Bold" Margin="12,10,12,8"/>
                    <ListBox x:Name="PinnedList" Background="Transparent" BorderThickness="0" MaxHeight="500">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="8,4" Padding="10" Background="{DynamicResource KokoCardBrush}" CornerRadius="6" BorderThickness="1" BorderBrush="{DynamicResource AccentBgBorder2}">
                                    <TextBlock Text="{Binding Content}" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource AccentText}" FontSize="10"/>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <!-- Input Area with Tools -->
            <Border Grid.Row="1" Background="{DynamicResource KokoInputPanelBrush}" BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="0,1,0,0">
                <StackPanel Margin="15">
                    <!-- Formatting Toolbar -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button x:Name="BoldButton" Content="Bold" Style="{StaticResource ToolButton}" Margin="0,0,5,0" Click="FormatBold_Click"/>
                        <Button x:Name="ItalicButton" Content="Italic" Style="{StaticResource ToolButton}" Margin="0,0,5,0" Click="FormatItalic_Click"/>
                        <Button x:Name="CodeButton" Content="Code" Style="{StaticResource ToolButton}" Margin="0,0,5,0" Click="FormatCode_Click"/>
                        <Button x:Name="QuoteButton" Content="Quote" Style="{StaticResource ToolButton}" Margin="0,0,5,0" Click="FormatQuote_Click"/>
                        <Separator Background="{DynamicResource AccentBgBorder2}" Width="1" Margin="5,0"/>
                        <Button x:Name="RecordButton" Content="🎤 Record" Style="{StaticResource ToolButton}" Margin="0,0,5,0" Click="RecordVoice_Click"/>
                        <Button x:Name="PinButton" Content="📌 Pin" Style="{StaticResource ToolButton}" Margin="0,0,5,0" Click="PinMessage_Click"/>
                        <Button x:Name="ExportButton" Content="📤 Export" Style="{StaticResource ToolButton}" Margin="0,0,5,0" Click="ExportChat_Click"/>
                        <Button x:Name="SummarizeButton" Content="📊 Summary" Style="{StaticResource ToolButton}" Click="SummarizeChat_Click"/>
                    </StackPanel>

                    <!-- Input Box -->
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="InputTextBox" Style="{StaticResource ModernTextBox}" Height="60" VerticalAlignment="Top" TextWrapping="Wrap" AcceptsReturn="True"/>
                        <Button x:Name="SendButton" Style="{StaticResource ModernButton}" Content="Send ▶" Width="100" Height="60" Margin="10,0,0,0" Click="SendMessage_Click" VerticalAlignment="Top"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Window>
