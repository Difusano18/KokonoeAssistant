                                                               Foreground="{DynamicResource AccentDim}" FontSize="10"
                                                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <Button x:Name="SendBtn" Style="{StaticResource BtnPrimary}"
                                                            Padding="16,7" Click="Send_Click">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="Send" FontSize="12"/>
                                                            <TextBlock Text=" &#x25B6;" FontSize="11" Margin="2,0,0,0"/>
                                                        </StackPanel>
