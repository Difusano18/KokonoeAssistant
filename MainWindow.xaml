                                <StackPanel Grid.Column="3" Margin="0,0,12,0" Visibility="Collapsed">
                                    <TextBlock Text="РђР’РўРћРќРћРњРќР†РЎРўР¬" FontSize="9" FontFamily="Consolas" FontWeight="Bold"
                                               Foreground="{DynamicResource AccentBase}"/>
                                    <TextBlock x:Name="LiveCoreAutonomyText" Text="СЂС–С€РµРЅРЅСЏ --"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentTextLight}" Margin="0,3,0,0"
                                               TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                                    <TextBlock x:Name="LiveCorePresenceText" Text="presence --"
                                               FontSize="10" Foreground="{DynamicResource Brush_8AC8A0}"
