                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="СИСТЕМА"
                                                       Style="{StaticResource DashSecHdr}"/>
                                            <Grid Grid.Row="1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>
                                                <Border Grid.Row="0" Grid.Column="0" Background="#0E0E18"
                                                        BorderBrush="#1A1A2A" BorderThickness="1" CornerRadius="6"
                                                        Padding="12" Margin="0,0,5,5">
                                                    <StackPanel>
                                                        <TextBlock Text="MINI APP" FontSize="9" Foreground="#5A5A6E"/>
                                                        <TextBlock x:Name="DashSysMiniAppStatus" Text="—"
                                                                   FontSize="13" FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource AccentBase}"
                                                                   Margin="0,4,0,0"/>
                                                        <TextBlock x:Name="DashSysMiniAppUrl" Text=""
                                                                   FontSize="9" Foreground="#5A5A6E"
                                                                   TextWrapping="Wrap" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border Grid.Row="0" Grid.Column="1" Background="#0E0E18"
                                                        BorderBrush="#1A1A2A" BorderThickness="1" CornerRadius="6"
                                                        Padding="12" Margin="5,0,0,5">
                                                    <StackPanel>
                                                        <TextBlock Text="TUNNEL" FontSize="9" Foreground="#5A5A6E"/>
                                                        <TextBlock x:Name="DashSysTunnelStatus" Text="—"
                                                                   FontSize="13" FontWeight="SemiBold"
                                                                   Foreground="#22D3EE" Margin="0,4,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border Grid.Row="1" Grid.Column="0" Background="#0E0E18"
                                                        BorderBrush="#1A1A2A" BorderThickness="1" CornerRadius="6"
                                                        Padding="12" Margin="0,0,5,5">
                                                    <StackPanel>
                                                        <TextBlock Text="UPTIME" FontSize="9" Foreground="#5A5A6E"/>
                                                        <TextBlock x:Name="DashSysUptime" Text="—"
                                                                   FontSize="13" FontWeight="SemiBold"
                                                                   Foreground="#E0E0EE" Margin="0,4,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border Grid.Row="1" Grid.Column="1" Background="#0E0E18"
                                                        BorderBrush="#1A1A2A" BorderThickness="1" CornerRadius="6"
                                                        Padding="12" Margin="5,0,0,5">
                                                    <StackPanel>
                                                        <TextBlock Text="MEMORY (RAM)" FontSize="9" Foreground="#5A5A6E"/>
                                                        <TextBlock x:Name="DashSysRam" Text="—"
                                                                   FontSize="13" FontWeight="SemiBold"
                                                                   Foreground="#E0E0EE" Margin="0,4,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </Grid>

                                <!-- RIGHT SIDEBAR: Monologue (always visible) -->
                                <Border Grid.Column="2" Style="{StaticResource DashPanel}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="INTERNAL MONOLOGUE"
                                                   Style="{StaticResource DashSecHdr}"/>
                                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled">
                                            <ItemsControl x:Name="DashThoughtStream">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,0,0,7">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="36"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding Time}"
                                                                       FontSize="7" Foreground="#3A2F4E"
                                                                       VerticalAlignment="Top" Margin="0,2,4,0"/>
                                                            <StackPanel Grid.Column="1">
                                                                <TextBlock Text="{Binding Thought}"
                                                                           Foreground="#B8A8D0" FontSize="9" TextWrapping="Wrap"/>
                                                                <TextBlock Text="{Binding MoodTag}"
                                                                           FontSize="7" Foreground="#3A2F4E"
                                                                           FontStyle="Italic" Margin="0,1,0,0"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                        <Border Grid.Row="2" BorderBrush="#1A1230"
                                                BorderThickness="0,1,0,0" Margin="0,8,0,0" Padding="0,8,0,0">
                                            <StackPanel>
                                                <TextBlock Text="INTERESTS" FontSize="9" FontWeight="SemiBold"
                                                           Foreground="#3A3A4E" Margin="0,0,0,5"/>
                                                <ItemsControl x:Name="DashCuriosityList">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding}" Foreground="#FFD700"
                                                                       FontSize="8" TextWrapping="Wrap" Margin="0,0,0,4">
                                                                <TextBlock.Effect>
                                                                    <DropShadowEffect Color="#FFD700" ShadowDepth="0" BlurRadius="4" Opacity="0.2"/>
                                                                </TextBlock.Effect>
                                                            </TextBlock>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Row="3" BorderBrush="#1A1230"
                                                BorderThickness="0,1,0,0" Margin="0,8,0,0" Padding="0,8,0,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="bond" FontSize="8" Foreground="#3A2F4E"/>
                                                    <TextBlock x:Name="DashSideBondLabel" Text="KNOWN"
                                                               FontSize="11" FontWeight="Bold"
                                                               Foreground="{StaticResource KokoPink}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                    <TextBlock Text="connection" FontSize="8" Foreground="#3A2F4E" HorizontalAlignment="Right"/>
                                                    <TextBlock x:Name="DashSideConnValue" Text="50%"
                                                               FontSize="18" FontWeight="Bold"
                                                               Foreground="{StaticResource KokoPink}" HorizontalAlignment="Right"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Border>
                            </Grid>

                            <!-- FOOTER -->
                            <Grid Grid.Row="3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="DashFooterComment"
                                           Text=""
                                           FontSize="9" Foreground="{StaticResource DashMuted}"
                                           FontStyle="Italic" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="BUILD 2026.04.18"
                                           FontSize="9" Foreground="{StaticResource DashVeryMuted}" VerticalAlignment="Center"/>
                            </Grid>
                        </Grid>

                        <!-- MCP Tools overlay (bottom strip) -->
                        <Border VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="14,0,14,30"
                                Background="#131318" BorderBrush="#2A2A35" BorderThickness="1" CornerRadius="8" Padding="12,8">
                            <StackPanel>
                                <TextBlock Text="OBSIDIAN MCP" FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentBase}" Margin="0,0,0,8"/>
                                <WrapPanel>
                                    <Button Content="List"       Style="{StaticResource BtnGhost}" Padding="8,4" Margin="0,0,4,4" Click="McpListNotes_Click"/>
                                    <Button Content="Search"     Style="{StaticResource BtnGhost}" Padding="8,4" Margin="0,0,4,4" Click="McpSearch_Click"/>
                                    <Button Content="Daily"      Style="{StaticResource BtnGhost}" Padding="8,4" Margin="0,0,4,4" Click="McpDailyNote_Click"/>
                                    <Button Content="New note"   Style="{StaticResource BtnGhost}" Padding="8,4" Margin="0,0,4,4" Click="McpNewNote_Click"/>
                                    <Button Content="Graph"      Style="{StaticResource BtnGhost}" Padding="8,4" Margin="0,0,4,4" Click="McpBuildGraph_Click"/>
                                    <Button Content="Visualize"  Style="{StaticResource BtnGhost}" Padding="8,4" Margin="0,0,4,4" Click="OpenKnowledgeGraph_Click"/>
                                </WrapPanel>
                                <Border Background="#0C0C10" CornerRadius="4" Margin="0,6,0,0" Padding="8" MinHeight="40">
                                    <TextBlock x:Name="McpOutput" Foreground="#5A5A6E"
                                               FontSize="10" FontFamily="Cascadia Code, Consolas" TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- ╔══════════ TELEGRAM TAB ══════════╗ -->
                    <Grid x:Name="TelegramTab" Visibility="Collapsed" Background="Transparent">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="{DynamicResource AccentBgDarker}"
                                BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="0,0,0,1" Padding="16,10">
                            <StackPanel Orientation="Horizontal">
                                <Border x:Name="TgStatusDot" Width="8" Height="8" CornerRadius="4"
                                        Background="{DynamicResource Brush_1A3020}" Margin="0,0,8,0" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource Brush_1A3020}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ElementName=TgStatusDot, Path=Tag}" Value="online">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBase}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                                <TextBlock Text="TELEGRAM" FontSize="11" FontWeight="Bold"
                                           Foreground="{DynamicResource AccentBase}" FontFamily="Consolas" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TgStatusLabel" Text=" · не підключено"
                                           FontSize="11" Foreground="{DynamicResource Brush_2A4232}" VerticalAlignment="Center"/>
                                <Button x:Name="TgConnectBtn" Content="⟳ Connect MTProto"
                                        FontSize="10" FontFamily="Consolas"
                                        Background="Transparent" BorderThickness="1"
                                        BorderBrush="{DynamicResource AccentAsstBorder}"
                                        Foreground="{DynamicResource AccentBase}"
                                        Padding="8,3" Margin="12,0,0,0"
                                        Click="TgConnectBtn_Click"/>
                            </StackPanel>
                        </Border>

                        <ScrollViewer x:Name="TgScroll" Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto" Padding="14,8">
                            <ItemsControl x:Name="TgMessagesList">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><StackPanel/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="10,6" Margin="0,2"
                                                BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="0,0,0,1">
                                            <TextBlock Text="{Binding}" TextWrapping="Wrap"
                                                       Foreground="{DynamicResource Brush_8AC8A0}" FontSize="12"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <Border Grid.Row="2" Background="{DynamicResource AccentBgDarker}"
                                BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="0,1,0,0" Padding="12,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TgInput" Style="{StaticResource InputBox}"
                                         Height="40" Padding="10,8" KeyDown="TgInput_KeyDown"/>
                                <Button Grid.Column="1" Content="Send ▶"
                                        Style="{StaticResource BtnPrimary}"
                                        Padding="16,0" Width="90" Height="40"
                                        Margin="8,0,0,0" Click="TgSend_Click"/>
                            </Grid>
                        </Border>
                    </Grid>

                </Grid>
            </Grid>

            <!-- ══════════════ LOADING OVERLAY ══════════════ -->
            <Grid x:Name="LoadingOverlay" Grid.RowSpan="2"
                  Background="{DynamicResource AccentBgMain}" Panel.ZIndex="100">

                <Grid.Triggers>
                    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                <DoubleAnimation Storyboard.TargetName="GlowRing"
                                                 Storyboard.TargetProperty="Opacity"
                                                 From="0.10" To="0.38" Duration="0:0:2.2">
                                    <DoubleAnimation.EasingFunction>
                                        <SineEase EasingMode="EaseInOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="GlowScaleX"
                                                 Storyboard.TargetProperty="ScaleX"
                                                 From="0.90" To="1.10" Duration="0:0:2.2">
                                    <DoubleAnimation.EasingFunction>
                                        <SineEase EasingMode="EaseInOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="GlowScaleX"
                                                 Storyboard.TargetProperty="ScaleY"
                                                 From="0.90" To="1.10" Duration="0:0:2.2">
                                    <DoubleAnimation.EasingFunction>
                                        <SineEase EasingMode="EaseInOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Grid.Triggers>

                <!-- Matrix rain canvas — hidden but kept for code-behind -->
                <Canvas x:Name="MatrixCanvas" Visibility="Collapsed"/>

                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                    <!-- Pulsing accent ring -->
                    <Grid HorizontalAlignment="Center" Margin="0,0,0,32" Width="72" Height="72">
                        <Ellipse x:Name="GlowRing" Width="72" Height="72"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                 Opacity="0.15">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="{DynamicResource AccentBaseColor}" Offset="0"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                            <Ellipse.RenderTransform>
                                <ScaleTransform x:Name="GlowScaleX" CenterX="36" CenterY="36"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        <Ellipse Width="48" Height="48" HorizontalAlignment="Center" VerticalAlignment="Center"
                                 Stroke="{DynamicResource AccentBase}" StrokeThickness="2" Opacity="0.4"/>
                        <TextBlock Text="◈" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{DynamicResource AccentBase}"/>
                    </Grid>

                    <!-- App name -->
                    <TextBlock Text="Kokonoe" FontSize="22" FontWeight="SemiBold"
                               Foreground="#E0E0EE" FontFamily="Segoe UI Variable, Segoe UI"
                               HorizontalAlignment="Center" Margin="0,0,0,4"/>

                    <TextBlock Text="Initializing workspace..." FontSize="11"
                               Foreground="#3A3A4E" FontFamily="Segoe UI Variable, Segoe UI"
                               HorizontalAlignment="Center" Margin="0,0,0,34"/>

                    <!-- Progress bar -->
                    <Border Width="260" Height="2" Background="#1A1A22"
                            CornerRadius="1" HorizontalAlignment="Center" Margin="0,0,0,12">
                        <Border x:Name="LoadingBar" HorizontalAlignment="Left"
                                Width="0" Height="2" Background="{DynamicResource AccentBase}" CornerRadius="1"/>
                    </Border>

                    <!-- Status text -->
                    <TextBlock x:Name="LoadingStatus" Text="loading..."
                               FontSize="10" Foreground="#3A3A4E"
                               FontFamily="Segoe UI Variable, Segoe UI"
                               HorizontalAlignment="Center" Margin="0,0,0,36"/>

                    <!-- Generated greeting preview -->
                    <Border x:Name="GreetingPreviewBorder" Visibility="Collapsed"
                            MaxWidth="480" Background="#131318"
                            BorderBrush="#2A2A35" BorderThickness="1"
                            CornerRadius="10" Padding="20,15">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,9">
                                <Ellipse Width="8" Height="8" Fill="{DynamicResource AccentBase}"
                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Kokonoe" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentBase}"/>
                            </StackPanel>
                            <TextBlock x:Name="GreetingPreviewText"
                                       TextWrapping="Wrap" FontSize="13"
                                       Foreground="#C0C0D4" FontFamily="Segoe UI Variable, Segoe UI"
                                       LineHeight="22"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Grid>

        <!-- ══════════════ SETTINGS PANEL (inline overlay) ══════════════ -->
        <Grid x:Name="SettingsOverlay" Grid.RowSpan="2" Visibility="Collapsed"
              Background="#B2000000">
            <Grid.RenderTransform>
                <TranslateTransform x:Name="SettingsTranslate" X="0"/>
            </Grid.RenderTransform>

            <!-- Panel itself — slides in from right -->
            <Border x:Name="SettingsPanel"
                    HorizontalAlignment="Right" Width="480"
                    Background="#0E0E14"
                    BorderBrush="#2A2A35" BorderThickness="1,0,0,0">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="SettingsPanelTranslate" X="480"/>
                </Border.RenderTransform>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="52"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" Background="#0A0A12"
                            BorderBrush="#1A1A22" BorderThickness="0,0,0,1">
                        <Grid Margin="12,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="← Back"
                                    FontFamily="Segoe UI Variable, Segoe UI" FontSize="12"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="#6B6B80"
                                    Padding="4,0" Cursor="Hand"
                                    Click="CloseSettings_Click"/>
                            <TextBlock Grid.Column="1" Text="Settings"
                                       FontFamily="Segoe UI Variable, Segoe UI" FontSize="14" FontWeight="SemiBold"
                                       Foreground="#E0E0EE"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Scrollable content -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16">
                        <StackPanel>

                            <!-- ── LLM ── -->
                            <TextBlock Text="LLM" Style="{StaticResource SettingsSectionHeader}"/>

                            <!-- Provider Switcher (4 режими) -->
                            <WrapPanel Margin="0,0,0,12">
                                <RadioButton x:Name="SP_ProviderLmStudio" Content="LM Studio" GroupName="LlmProvider"
                                             FontFamily="Segoe UI Variable, Segoe UI" FontSize="12"
                                             Foreground="#9090A8" VerticalAlignment="Center" Margin="0,0,14,6"
                                             Checked="Provider_Checked"/>
                                <RadioButton x:Name="SP_ProviderOllama" Content="Ollama (local)" GroupName="LlmProvider"
                                             FontFamily="Segoe UI Variable, Segoe UI" FontSize="12"
                                             Foreground="#9090A8" VerticalAlignment="Center" Margin="0,0,14,6"
                                             Checked="Provider_Checked"/>
                                <RadioButton x:Name="SP_ProviderOllamaCloud" Content="Ollama Cloud" GroupName="LlmProvider"
                                             FontFamily="Segoe UI Variable, Segoe UI" FontSize="12"
                                             Foreground="#9090A8" VerticalAlignment="Center" Margin="0,0,14,6"
                                             Checked="Provider_Checked"/>
                                <RadioButton x:Name="SP_ProviderClaude" Content="Claude API" GroupName="LlmProvider"
                                             FontFamily="Segoe UI Variable, Segoe UI" FontSize="12"
                                             Foreground="#9090A8" VerticalAlignment="Center" Margin="0,0,0,6"
                                             Checked="Provider_Checked"/>
                            </WrapPanel>

                            <!-- URL group (тільки local: LM Studio / Ollama local) -->
                            <StackPanel x:Name="SP_UrlGroup">
                                <TextBlock Text="URL" Style="{StaticResource SettingsLabel}"/>
                                <TextBox x:Name="SP_LmUrl" Style="{StaticResource SettingInput}" Margin="0,0,0,6"/>
                                <TextBlock x:Name="SP_UrlHint"
                                           Foreground="#3A3A4E" FontFamily="Segoe UI Variable, Segoe UI" FontSize="10"
                                           Margin="0,0,0,12" TextWrapping="Wrap"/>
                            </StackPanel>

                            <!-- API Key group (тільки Claude — single-key) -->
                            <StackPanel x:Name="SP_ApiKeyGroup" Visibility="Collapsed">
                                <TextBlock x:Name="SP_ApiKeyLabel" Text="API Key" Style="{StaticResource SettingsLabel}"/>
                                <TextBox x:Name="SP_ApiKeyBox" Style="{StaticResource SettingInput}"
                                         Margin="0,0,0,6" TextChanged="SP_ApiKey_TextChanged"/>
                                <TextBlock x:Name="SP_ApiKeyHint"
                                           Foreground="#3A3A4E" FontFamily="Segoe UI Variable, Segoe UI" FontSize="10"
                                           Margin="0,0,0,12" TextWrapping="Wrap"/>
                            </StackPanel>

                            <!-- Ollama Cloud — пул ключів (тільки для провайдера ollama-cloud) -->
                            <StackPanel x:Name="SP_OllamaPoolGroup" Visibility="Collapsed">
                                <TextBlock Text="Pool параметри" Style="{StaticResource SettingsLabel}"/>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                        <TextBlock Text="Ліміт/год" Foreground="#6B6B80"
                                                   FontFamily="Segoe UI Variable, Segoe UI" FontSize="10" Margin="0,0,0,2"/>
                                        <TextBox x:Name="SP_OllamaMaxPerHour" Style="{StaticResource SettingInput}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="2,0,2,0">
                                        <TextBlock Text="Ротація на %" Foreground="#6B6B80"
                                                   FontFamily="Segoe UI Variable, Segoe UI" FontSize="10" Margin="0,0,0,2"/>
                                        <TextBox x:Name="SP_OllamaRotateAt" Style="{StaticResource SettingInput}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Margin="4,0,0,0">
                                        <TextBlock Text="Cooldown (хв)" Foreground="#6B6B80"
                                                   FontFamily="Segoe UI Variable, Segoe UI" FontSize="10" Margin="0,0,0,2"/>
                                        <TextBox x:Name="SP_OllamaCooldown" Style="{StaticResource SettingInput}"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="Ключі" Style="{StaticResource SettingsLabel}"/>
                                <ItemsControl x:Name="SP_OllamaKeysList" Margin="0,0,0,8">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#0A0A12" BorderBrush="#1A1A22" BorderThickness="1"
                                                    CornerRadius="4" Padding="8,6" Margin="0,0,0,4">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="14"/>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Ellipse Grid.Column="0" Width="8" Height="8"
                                                             Fill="{Binding ActiveDotBrush}" VerticalAlignment="Center"/>
                                                    <TextBox Grid.Column="1"
                                                             Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{StaticResource SettingInput}"
                                                             Margin="6,0,6,0" Padding="6,3"/>
                                                    <TextBox Grid.Column="2"
                                                             Text="{Binding Key, UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{StaticResource SettingInput}"
                                                             FontFamily="Consolas" Padding="6,3"/>
                                                    <TextBlock Grid.Column="3" Text="{Binding StatusText}"
                                                               Foreground="{Binding StatusBrush}"
                                                               FontFamily="Consolas" FontSize="11"
                                                               Margin="8,0,4,0" VerticalAlignment="Center"/>
                                                    <Button Grid.Column="4" Content="✕"
                                                            Click="SP_RemoveKey_Click" Tag="{Binding}"
                                                            Background="Transparent" BorderThickness="0"
                                                            Foreground="#6B6B80" FontSize="11"
                                                            Padding="6,2" Cursor="Hand"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Button x:Name="SP_AddKeyBtn" Content="+ Додати ключ"
                                        Click="SP_AddKey_Click"
                                        Background="#1A1A22" BorderBrush="#2A2A35" BorderThickness="1"
                                        Foreground="#9090A8" FontFamily="Segoe UI Variable, Segoe UI"
                                        FontSize="11" Padding="10,6" Cursor="Hand" HorizontalAlignment="Left"
                                        Margin="0,0,0,8"/>

                                <TextBlock Text="Ollama Cloud free-tier має квоту на акаунт. Додай 5-10 ключів з різних акаунтів — Коконое автоматично переключиться коли активний дотягне порогу."
                                           Foreground="#3A3A4E" FontFamily="Segoe UI Variable, Segoe UI" FontSize="10"
                                           TextWrapping="Wrap" Margin="0,0,0,12"/>
                            </StackPanel>

                            <!-- Model -->
                            <TextBlock Text="Модель" Style="{StaticResource SettingsLabel}"/>
                            <TextBox x:Name="SP_ModelBox" Style="{StaticResource SettingInput}" Margin="0,0,0,6"/>
                            <TextBlock x:Name="SP_ModelHint"
                                       Foreground="#3A3A4E" FontFamily="Segoe UI Variable, Segoe UI" FontSize="10"
                                       Margin="0,0,0,16" TextWrapping="Wrap"/>

                            <!-- ── TELEGRAM BOT ── -->
                            <TextBlock Text="TELEGRAM BOT" Style="{StaticResource SettingsSectionHeader}"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <CheckBox x:Name="SP_TgEnabled" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Увімкнути бот" Style="{StaticResource SettingsLabel}" Margin="0"/>
                            </StackPanel>
                            <TextBlock Text="Bot Token" Style="{StaticResource SettingsLabel}"/>
                            <TextBox x:Name="SP_TgToken" Style="{StaticResource SettingInput}" Margin="0,0,0,10"/>
                            <TextBlock Text="Chat ID" Style="{StaticResource SettingsLabel}"/>
                            <TextBox x:Name="SP_TgChatId" Style="{StaticResource SettingInput}" Margin="0,0,0,16"/>

                            <!-- ── TELEGRAM USER CLIENT ── -->
                            <TextBlock Text="TELEGRAM USER CLIENT" Style="{StaticResource SettingsSectionHeader}"/>
                            <TextBlock Text="Повний доступ до акаунту. API ID і Hash — my.telegram.org → App API"
                                       FontFamily="Consolas" FontSize="10" Foreground="#4A7A5A"
                                       TextWrapping="Wrap" Margin="0,0,0,10"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <CheckBox x:Name="SP_TgUserEnabled" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Увімкнути User Client" Style="{StaticResource SettingsLabel}" Margin="0"/>
                            </StackPanel>
                            <TextBlock Text="API ID" Style="{StaticResource SettingsLabel}"/>
                            <TextBox x:Name="SP_TgApiId" Style="{StaticResource SettingInput}" Margin="0,0,0,10"/>
                            <TextBlock Text="API Hash" Style="{StaticResource SettingsLabel}"/>
                            <TextBox x:Name="SP_TgApiHash" Style="{StaticResource SettingInput}" Margin="0,0,0,10"/>
                            <TextBlock Text="Номер телефону (+34...)" Style="{StaticResource SettingsLabel}"/>
                            <TextBox x:Name="SP_TgPhone" Style="{StaticResource SettingInput}" Margin="0,0,0,10"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <CheckBox x:Name="SP_TgDmOnly" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Тільки DM (ігнорувати групи/канали)" Style="{StaticResource SettingsLabel}" Margin="0"/>
                            </StackPanel>

                            <!-- ── VOICE ── -->
                            <TextBlock Text="VOICE" Style="{StaticResource SettingsSectionHeader}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <CheckBox x:Name="SP_Voice" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Голосовий ввід (Whisper)" Style="{StaticResource SettingsLabel}" Margin="0"/>
                            </StackPanel>
                            <TextBlock Text="OpenAI API Key (Whisper)" Style="{StaticResource SettingsLabel}"/>
                            <TextBox x:Name="SP_OpenAiKey" Style="{StaticResource SettingInput}" Margin="0,0,0,16"/>

                            <!-- ── СИСТЕМА ── -->
                            <TextBlock Text="СИСТЕМА" Style="{StaticResource SettingsSectionHeader}"/>
                            <TextBlock Text="Vault Path" Style="{StaticResource SettingsLabel}"/>
                            <TextBox x:Name="SP_VaultPath" Style="{StaticResource SettingInput}" Margin="0,0,0,10"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <CheckBox x:Name="SP_Spont" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Спонтанні повідомлення" Style="{StaticResource SettingsLabel}" Margin="0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <CheckBox x:Name="SP_Tray" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Мінімізувати в трей" Style="{StaticResource SettingsLabel}" Margin="0"/>
                            </StackPanel>

                            <!-- ── ТЕМА ── -->
                            <TextBlock Text="ТЕМА / АКЦЕНТ RGB" Style="{StaticResource SettingsSectionHeader}"/>
                            <TextBlock Text="HEX колір акценту" Style="{StaticResource SettingsLabel}"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="SP_AccentColor" Style="{StaticResource SettingInput}"/>
                                <Border Grid.Column="1" x:Name="SP_ColorPreview"
                                        Width="34" Height="34" Margin="6,0,0,0"
                                        CornerRadius="4" Background="#00E676"
                                        Cursor="Hand" MouseLeftButtonDown="SP_ColorPreview_Click"/>
                            </Grid>
                            <!-- Swatches -->
                            <WrapPanel Margin="0,0,0,6">
                                <Border Width="28" Height="28" CornerRadius="14" Margin="3" Background="#00E676" Cursor="Hand" MouseLeftButtonDown="SP_Swatch_Click" Tag="#00E676"/>
                                <Border Width="28" Height="28" CornerRadius="14" Margin="3" Background="#00BCD4" Cursor="Hand" MouseLeftButtonDown="SP_Swatch_Click" Tag="#00BCD4"/>
                                <Border Width="28" Height="28" CornerRadius="14" Margin="3" Background="#E040FB" Cursor="Hand" MouseLeftButtonDown="SP_Swatch_Click" Tag="#E040FB"/>
                                <Border Width="28" Height="28" CornerRadius="14" Margin="3" Background="#FF5252" Cursor="Hand" MouseLeftButtonDown="SP_Swatch_Click" Tag="#FF5252"/>
                                <Border Width="28" Height="28" CornerRadius="14" Margin="3" Background="#FFD740" Cursor="Hand" MouseLeftButtonDown="SP_Swatch_Click" Tag="#FFD740"/>
                                <Border Width="28" Height="28" CornerRadius="14" Margin="3" Background="#FF6D00" Cursor="Hand" MouseLeftButtonDown="SP_Swatch_Click" Tag="#FF6D00"/>
                                <Border Width="28" Height="28" CornerRadius="14" Margin="3" Background="#FFFFFF" Cursor="Hand" MouseLeftButtonDown="SP_Swatch_Click" Tag="#FFFFFF"/>
                            </WrapPanel>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- Save button -->
                    <Border Grid.Row="2" Background="#0A0A12"
                            BorderBrush="#1A1A22" BorderThickness="0,1,0,0"
                            Padding="20,12">
                        <Button Content="Save settings" Click="SP_Save_Click"
                                Background="{DynamicResource AccentBase}"
                                Foreground="White" FontFamily="Segoe UI Variable, Segoe UI"
                                FontSize="13" FontWeight="SemiBold"
                                BorderThickness="0" Height="40"
                                Cursor="Hand"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        </Grid>
    </Border>
</Window>




