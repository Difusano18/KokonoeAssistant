<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="KokonoeAssistant.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Kokonoe" Height="900" Width="1380"
        MinHeight="620" MinWidth="900"
        Background="{DynamicResource AccentBgMain}"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="Manual"
        Loaded="Window_Loaded"
        Icon="Logo/Logo_icon.ico">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome ResizeBorderThickness="6" CaptionHeight="0"
                            GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>

        <!-- ─── SCROLLBAR ───────────────────────────────────────── -->
        <Style x:Key="KokoScrollThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{DynamicResource AccentScrollThm}" CornerRadius="2"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource KokoScrollThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ─── BUTTON: Primary ────────────────────────────────── -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource AccentPrimary}"/>
            <Setter Property="Foreground"      Value="{DynamicResource Brush_030B05}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentBase}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentDark}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource Brush_142018}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Brush_2A4030}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ─── BUTTON: Ghost ──────────────────────────────────── -->
        <Style x:Key="BtnGhost" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource AccentMuted}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource Brush_163025}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentNavBg}"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource AccentBase}"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentTextLight}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource Brush_071008}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ─── BUTTON: Nav (left sidebar) ───────────────────── -->
        <Style x:Key="BtnNav" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#5A5A6E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Height"          Value="40"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Margin="8,2">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"
                                              Margin="12,0,0,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1A1A22"/>
                                <Setter Property="Foreground" Value="#9090A8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnNavActive" TargetType="Button">
            <Setter Property="Background"      Value="#1E1E3F"/>
            <Setter Property="Foreground"      Value="{DynamicResource AccentBase}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Height"          Value="40"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="bd" Background="#1E1E3F" CornerRadius="6" Margin="8,2">
                                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"
                                                  Margin="12,0,0,0"/>
                            </Border>
                            <Rectangle Width="3" HorizontalAlignment="Left" RadiusX="2" RadiusY="2"
                                       Fill="{DynamicResource AccentBase}" Margin="8,8,0,8"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Aliases for code-behind compatibility -->
        <Style x:Key="BtnTab"       TargetType="Button" BasedOn="{StaticResource BtnNav}"/>
        <Style x:Key="BtnTabActive" TargetType="Button" BasedOn="{StaticResource BtnNavActive}"/>

        <!-- ─── BUTTON: Chrome ─────────────────────────────────── -->
        <Style x:Key="ChromeBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource Brush_2A4232}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="30"/>
            <Setter Property="Height"          Value="30"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentNavBg}"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentMuted}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ─── TEXTBOX ───────────────────────────────────────── -->
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background"      Value="{DynamicResource AccentBgInput}"/>
            <Setter Property="Foreground"      Value="{DynamicResource AccentTextLight}"/>
            <Setter Property="CaretBrush"      Value="{DynamicResource AccentBase}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource AccentAsstBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Padding"         Value="12,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource AccentBase}"/>
                                <Setter TargetName="bd" Property="Background"  Value="{DynamicResource Brush_0A1A0D}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ─── LISTBOX ───────────────────────────────────────── -->
        <Style x:Key="CleanListBox" TargetType="ListBox">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>
        <Style x:Key="CleanListItem" TargetType="ListBoxItem">
            <Setter Property="Background"                 Value="Transparent"/>
            <Setter Property="BorderThickness"            Value="0"/>
            <Setter Property="Padding"                    Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentNavBg}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentListHovBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ─── HEALTH SLIDER ─────────────────────────────────── -->
        <Style x:Key="HealthSlider" TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" Background="{DynamicResource AccentPrimary}" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" Background="{DynamicResource AccentAsstBorder}" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Width="14" Height="14" Background="{DynamicResource AccentBase}"
                                                        CornerRadius="7" BorderBrush="{DynamicResource AccentVeryLight}" BorderThickness="1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- ════════════ ROOT ════════════════ -->
    <Border Background="{DynamicResource AccentBgMain}"
            BorderBrush="{DynamicResource AccentBgBorder1}" BorderThickness="0,1,0,0"
            ClipToBounds="True">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ══════════════ TITLE BAR ══════════════ -->
            <Border Grid.Row="0" Background="{DynamicResource AccentBgDarker}"
                    BorderBrush="{DynamicResource AccentBgBorder1}" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Logo -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="16,0,0,0">
                        <Ellipse x:Name="EmotionDot" Width="8" Height="8" Margin="0,0,10,0"
                                 VerticalAlignment="Center" Fill="{DynamicResource AccentBase}"/>
                        <TextBlock Text="Kokonoe" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#A0A0B8" FontFamily="Segoe UI Variable, Segoe UI"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- drag area (middle — intentionally empty) -->
                    <Border Grid.Column="1"/>

                    <!-- Window controls -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="0,0,8,0">
                        <Button x:Name="ExportChatBtn" Content="💾" Style="{StaticResource ChromeBtn}"
                                Click="ExportChat_Click" ToolTip="Зберегти чат"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button x:Name="ClearChatBtn" Content="🗑" Style="{StaticResource ChromeBtn}"
                                Click="ClearChat_Click" ToolTip="Очистити чат"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button Content="⚙" Style="{StaticResource ChromeBtn}"
                                Click="OpenSettings_Click" ToolTip="Налаштування"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Border Width="1" Background="{DynamicResource AccentAsstBorder}" Margin="4,7"/>
                        <Button Content="─" Style="{StaticResource ChromeBtn}" Click="MinimizeBtn_Click"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button Content="□" Style="{StaticResource ChromeBtn}" Click="MaximizeBtn_Click"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button Content="✕" Click="CloseBtn_Click"
                                Width="30" Height="30" Cursor="Hand" BorderThickness="0"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                Background="Transparent" Foreground="{DynamicResource Brush_3A2020}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource Brush_2A0808}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource Brush_FF5555}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════════════ BODY ══════════════ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ─── LEFT NAV ─────────────────────────────────── -->
                <Border Grid.Column="0" Background="{DynamicResource AccentBgDarker}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Sidebar header -->
                        <Border Grid.Row="0" Padding="20,14,16,10"
                                BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="0,0,0,1">
                            <TextBlock Text="Workspace" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#3A3A4E" FontFamily="Segoe UI Variable, Segoe UI"/>
                        </Border>

                        <!-- Nav items -->
                        <StackPanel Grid.Row="1" Margin="0,8,0,0">

                            <Button x:Name="TabBtnChat" Style="{StaticResource BtnNavActive}" Click="Tab_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💬" FontSize="15" VerticalAlignment="Center" Width="20"/>
                                    <TextBlock Text="Chat" FontSize="12" VerticalAlignment="Center"
                                               FontFamily="Segoe UI Variable, Segoe UI" Margin="10,0,0,0"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="TabBtnVault" Style="{StaticResource BtnNav}" Click="Tab_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📁" FontSize="15" VerticalAlignment="Center" Width="20"/>
                                    <TextBlock Text="Vault" FontSize="12" VerticalAlignment="Center"
                                               FontFamily="Segoe UI Variable, Segoe UI" Margin="10,0,0,0"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="TabBtnHealth" Style="{StaticResource BtnNav}" Click="Tab_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📅" FontSize="15" VerticalAlignment="Center" Width="20"/>
                                    <TextBlock Text="Calendar" FontSize="12" VerticalAlignment="Center"
                                               FontFamily="Segoe UI Variable, Segoe UI" Margin="10,0,0,0"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="TabBtnTools" Style="{StaticResource BtnNav}" Click="Tab_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="◈" FontSize="15" VerticalAlignment="Center" Width="20"/>
                                    <TextBlock Text="Dashboard" FontSize="12" VerticalAlignment="Center"
                                               FontFamily="Segoe UI Variable, Segoe UI" Margin="10,0,0,0"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="TabBtnTelegram" Style="{StaticResource BtnNav}" Click="Tab_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✈" FontSize="15" VerticalAlignment="Center" Width="20"/>
                                    <TextBlock Text="Telegram" FontSize="12" VerticalAlignment="Center"
                                               FontFamily="Segoe UI Variable, Segoe UI" Margin="10,0,0,0"/>
                                </StackPanel>
                            </Button>

                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Background="{DynamicResource AccentBgBorder2}"/>

                <!-- ─── MAIN CONTENT ──────────────────────────────── -->
                <Grid Grid.Column="2">

                    <!-- ╔══════════ CHAT TAB ══════════╗ -->
                    <Grid x:Name="ChatTab" Background="Transparent">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Messages -->
                        <ScrollViewer x:Name="MessagesScroll" Grid.Row="0"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Background="Transparent"
                                      PreviewMouseWheel="MessagesScroll_PreviewMouseWheel">
                            <StackPanel x:Name="MessagesList" Margin="0,14,0,14"/>
                        </ScrollViewer>

                        <!-- Input panel -->
                        <Border Grid.Row="1" Background="{DynamicResource AccentBgDarker}"
                                BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="0,1,0,0"
                                Padding="18,12,18,16">
                            <StackPanel>

                                <!-- Image preview (hidden by default) -->
                                <Border x:Name="ImagePreviewBorder" Visibility="Collapsed"
                                        Background="{DynamicResource Brush_08180C}" CornerRadius="10"
                                        BorderBrush="{DynamicResource AccentAsstBorder}" BorderThickness="1"
                                        Padding="10,8" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Image x:Name="PendingImageThumb" MaxHeight="64" MaxWidth="96"
                                               Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Зображення" Foreground="{DynamicResource Brush_8AC8A0}"
                                                       FontSize="12" FontWeight="SemiBold"/>
                                            <TextBlock x:Name="PendingImageLabel" Foreground="{DynamicResource Brush_2A4832}" FontSize="10"/>
                                        </StackPanel>
                                        <Button Grid.Column="2" Content="✕" Background="Transparent"
                                                BorderThickness="0" Foreground="{DynamicResource Brush_2A4832}"
                                                FontSize="14" Cursor="Hand"
                                                Padding="6" Click="RemoveImage_Click" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <!-- Input container (glass card) -->
                                <Border Background="{DynamicResource Brush_071209}" CornerRadius="14"
                                        BorderBrush="{DynamicResource AccentAsstBorder}" BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsFocused, ElementName=InputBox}" Value="True">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentPrimary}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBox x:Name="InputBox" Grid.Row="0"
                                                 Background="Transparent" Foreground="{DynamicResource AccentTextLight}"
                                                 CaretBrush="{DynamicResource AccentBase}" BorderThickness="0"
                                                 FontSize="13" FontFamily="Segoe UI"
                                                 MinHeight="52" MaxHeight="160"
                                                 Padding="16,14,16,4"
                                                 TextWrapping="Wrap" AcceptsReturn="False"
                                                 VerticalScrollBarVisibility="Auto"
                                                 KeyDown="Input_KeyDown" AllowDrop="True"
                                                 Drop="Input_Drop"
                                                 PreviewKeyDown="Input_PreviewKeyDown">
                                            <TextBox.Template>
                                                <ControlTemplate TargetType="TextBox">
                                                    <ScrollViewer x:Name="PART_ContentHost"
                                                                  Padding="{TemplateBinding Padding}"
                                                                  VerticalScrollBarVisibility="Auto"/>
                                                </ControlTemplate>
                                            </TextBox.Template>
                                        </TextBox>

                                        <!-- Bottom action bar -->
                                        <Border Grid.Row="1" Padding="10,5,10,7"
                                                BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="0,1,0,0">
                                            <Grid>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Button x:Name="RecordBtn" ToolTip="Голос (Whisper)"
                                                            Style="{StaticResource BtnGhost}"
                                                            Padding="6,4" Margin="0,0,3,0" Click="Record_Click">
                                                        <TextBlock Text="🎤" FontSize="13"/>
                                                    </Button>
                                                    <Button ToolTip="Прикріпити фото (Ctrl+V / Drop)"
                                                            Style="{StaticResource BtnGhost}"
                                                            Padding="6,4" Margin="0,0,3,0" Click="AttachImage_Click">
                                                        <TextBlock Text="🖼" FontSize="13"/>
                                                    </Button>
                                                </StackPanel>

                                                <StackPanel Orientation="Horizontal"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="Enter — send  ·  Shift+Enter — newline"
                                                               Foreground="{DynamicResource Brush_142018}" FontSize="10"
                                                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <Button x:Name="SendBtn" Style="{StaticResource BtnPrimary}"
                                                            Padding="16,7" Click="Send_Click">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="Send" FontSize="12"/>
                                                            <TextBlock Text=" ▶" FontSize="11" Margin="2,0,0,0"/>
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- ╔══════════ VAULT TAB ══════════╗ -->
                    <Grid x:Name="VaultTab" Visibility="Collapsed" Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Vault sidebar -->
                        <Border Grid.Column="0" Background="{DynamicResource AccentBgDarker}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Padding="10,10,10,6"
                                        BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="0,0,0,1">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📁 VAULT" FontSize="10" FontWeight="Bold"
                                                   Foreground="{DynamicResource AccentBase}" FontFamily="Consolas" VerticalAlignment="Center"/>
                                        <Button Content="+" Style="{StaticResource BtnGhost}"
                                                Padding="6,2" Margin="8,0,0,0" FontSize="14"
                                                Click="NewNote_Click"/>
                                        <Button Content="↻" Style="{StaticResource BtnGhost}"
                                                Padding="6,2" Margin="4,0,0,0"
                                                Click="RefreshVault_Click"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="1" Padding="8,6,8,4">
                                    <Grid>
                                        <TextBox x:Name="VaultSearchBox" Style="{StaticResource InputBox}"
                                                 FontSize="11" Padding="28,7,8,7"
                                                 TextChanged="VaultSearch_Changed"/>
                                        <TextBlock Text="🔍" FontSize="11" Foreground="{DynamicResource Brush_1A3020}"
                                                   VerticalAlignment="Center" Margin="10,0,0,0"
                                                   IsHitTestVisible="False"/>
                                    </Grid>
                                </Border>

                                <TreeView x:Name="VaultTree" Grid.Row="2"
                                          Background="Transparent" BorderThickness="0"
                                          Foreground="{DynamicResource AccentMuted}" FontSize="11"
                                          Padding="4,0"
                                          SelectedItemChanged="VaultTree_Selected">
                                    <TreeView.Resources>
                                        <Style TargetType="TreeViewItem">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="{DynamicResource AccentMuted}"/>
                                            <Setter Property="Padding"    Value="4,3"/>
                                            <Setter Property="FontSize"   Value="11"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource AccentNavBg}"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource Brush_102818}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource AccentBase}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TreeView.Resources>
                                </TreeView>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Background="{DynamicResource AccentBgBorder2}"/>

                        <!-- Notes list + editor split -->
                        <Grid Grid.Column="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="1"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Flat notes list -->
                            <Border Grid.Column="0" Background="{DynamicResource Brush_050D07}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Padding="10,7"
                                            BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="0,0,0,1">
                                        <TextBlock Text="NOTES" FontSize="9" FontWeight="Bold"
                                                   Foreground="{DynamicResource Brush_1A3020}" FontFamily="Consolas"/>
                                    </Border>
                                    <ListBox x:Name="NotesList" Grid.Row="1"
                                             Background="Transparent" BorderThickness="0"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             SelectionChanged="NotesList_SelectionChanged"
                                             Foreground="{DynamicResource AccentMuted}">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Background"                 Value="Transparent"/>
                                                <Setter Property="BorderThickness"            Value="0"/>
                                                <Setter Property="Padding"                    Value="0"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsSelected"  Value="True">
                                                                    <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentNavBg}"/>
                                                                </Trigger>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentListHovBg}"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="10,6" BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="0,0,0,1">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Title}" FontSize="11" Foreground="{DynamicResource Brush_8AC8A0}"/>
                                                        <TextBlock Text="{Binding Path}"  FontSize="9"  Foreground="{DynamicResource Brush_1A3020}" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Border>

                            <Border Grid.Column="1" Background="{DynamicResource AccentBgBorder2}"/>

                            <!-- Editor -->
                            <Grid Grid.Column="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="{DynamicResource AccentBgDarker}"
                                        BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="0,0,0,1" Padding="14,8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="NotePathLabel" Text="Виберіть нотатку"
                                                   Foreground="{DynamicResource Brush_2A4232}" FontSize="11" VerticalAlignment="Center"/>
                                        <Button Content="💾 Save" Style="{StaticResource BtnGhost}"
                                                Padding="8,4" Margin="14,0,0,0" Click="SaveNote_Click"/>
                                        <Button Content="🗑 Delete" Style="{StaticResource BtnGhost}"
                                                Padding="8,4" Margin="4,0,0,0" Click="DeleteNote_Click"/>
                                    </StackPanel>
                                </Border>
                                <TextBox x:Name="NoteEditor" Grid.Row="1"
                                         Style="{StaticResource InputBox}"
                                         AcceptsReturn="True" TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         FontFamily="Consolas" FontSize="12"
                                         BorderThickness="0" Padding="16"/>
                                <Border Grid.Row="2" Background="{DynamicResource AccentBgDarker}"
                                        BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="0,1,0,0" Padding="12,5">
                                    <TextBlock x:Name="NoteStatsLabel" Foreground="{DynamicResource Brush_1A3020}" FontSize="10"/>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>

                    <!-- ╔══════════ HEALTH TAB ══════════╗ -->
                    <Grid x:Name="HealthTab" Visibility="Collapsed" Background="Transparent">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20">
                            <StackPanel MaxWidth="680">

                                <TextBlock Text="КАЛЕНДАР" FontSize="13" FontWeight="Bold"
                                           Foreground="{DynamicResource AccentBase}" FontFamily="Consolas" Margin="0,0,0,16"/>

                                <!-- Month navigation -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="30"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="CalPrevBtn" Content="◀" Style="{StaticResource BtnTab}"
                                            Click="CalPrev_Click" Width="26" Height="26" Padding="0" FontSize="10"/>
                                    <TextBlock x:Name="CalMonthLabel" Grid.Column="1"
                                               FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                                               Foreground="{DynamicResource AccentBase}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Button x:Name="CalNextBtn" Grid.Column="2" Content="▶" Style="{StaticResource BtnTab}"
                                            Click="CalNext_Click" Width="26" Height="26" Padding="0" FontSize="10"/>
                                </Grid>

                                <!-- Weekday header row -->
                                <Grid x:Name="CalWeekHeader" Margin="0,0,0,2"/>

                                <!-- Day cells -->
                                <Grid x:Name="CalDaysGrid" Margin="0,0,0,20"/>

                                <!-- Selected day panel -->
                                <Border x:Name="CalSelectedPanel" Background="{DynamicResource Brush_060F08}" CornerRadius="10"
                                        BorderBrush="{DynamicResource Brush_0F2818}" BorderThickness="1"
                                        Padding="16,14" Margin="0,0,0,20" Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock x:Name="CalSelectedLabel"
                                                   FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                                                   Foreground="{DynamicResource AccentBase}" Margin="0,0,0,10"/>

                                        <!-- Events for selected day -->
                                        <ItemsControl x:Name="CalEventsList" Margin="0,0,0,10">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="22"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="·" Foreground="{DynamicResource AccentBase}" Margin="0,0,6,0"/>
                                                            <TextBlock Text="{Binding TimeStr}" Foreground="{DynamicResource Brush_2A6040}"
                                                                       FontFamily="Consolas" FontSize="11" Margin="0,0,8,0"/>
                                                            <TextBlock Text="{Binding Title}" Foreground="{DynamicResource AccentMuted}" FontSize="12"/>
                                                        </StackPanel>
                                                        <Button Grid.Column="1" Content="×" Tag="{Binding Id}"
                                                                Foreground="{DynamicResource Brush_1A3020}" Background="Transparent"
                                                                BorderThickness="0" FontSize="14"
                                                                Cursor="Hand" Padding="0"
                                                                Click="DeleteEvent_Click"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Add event form -->
                                        <Border BorderBrush="{DynamicResource Brush_0F2818}" BorderThickness="0,1,0,0" Padding="0,10,0,0">
                                            <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="64"/>
                                                        <ColumnDefinition Width="76"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox x:Name="EventTitleBox" Style="{StaticResource InputBox}"
                                                             FontSize="11" Padding="8,6" Height="32"
                                                             ToolTip="Назва події"/>
                                                    <TextBox x:Name="EventTimeBox" Grid.Column="1"
                                                             Style="{StaticResource InputBox}"
                                                             FontSize="11" Padding="8,6" Height="32"
                                                             Margin="6,0" Text="17:00"
                                                             ToolTip="Час (напр. 17:00)"/>
                                                    <Button x:Name="AddEventBtn" Grid.Column="2"
                                                            Content="ДОДАТИ"
                                                            Style="{StaticResource BtnPrimary}"
                                                            FontSize="10" Height="32" Padding="0"
                                                            Click="AddEvent_Click"/>
                                                </Grid>
                                                <TextBox x:Name="EventDescBox" Style="{StaticResource InputBox}"
                                                         FontSize="11" Padding="8,6" Margin="0,6,0,0"
                                                         MinHeight="50" MaxHeight="120"
                                                         TextWrapping="Wrap" AcceptsReturn="True"
                                                         VerticalScrollBarVisibility="Auto"
                                                         ToolTip="Опис (необов'язково)"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- Upcoming events -->
                                <TextBlock Text="НАЙБЛИЖЧІ ПОДІЇ" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource AccentBase}" FontFamily="Consolas" Margin="0,0,0,10"/>
                                <ItemsControl x:Name="UpcomingEventsList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="8,7" BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="0,0,0,1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="22"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Title}"
                                                                   Foreground="{DynamicResource AccentMuted}" FontSize="12"/>
                                                        <TextBlock Text="{Binding DateStr}"
                                                                   Foreground="{DynamicResource Brush_2A4232}"
                                                                   FontFamily="Consolas" FontSize="10"/>
                                                    </StackPanel>
                                                    <Button Grid.Column="1" Content="×" Tag="{Binding Id}"
                                                            Foreground="{DynamicResource Brush_1A3020}" Background="Transparent"
                                                            BorderThickness="0" FontSize="14"
                                                            Cursor="Hand" Padding="0"
                                                            Click="DeleteEvent_Click"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- ╔══════════ TOOLS TAB ══════════╗ -->
                    <Grid x:Name="ToolsTab" Visibility="Collapsed"
                          Background="{DynamicResource AccentBgMain}"
                          SizeChanged="DashboardSizeChanged"
                          TextBlock.FontFamily="Segoe UI Variable, Segoe UI">
                        <Grid.Resources>
                            <SolidColorBrush x:Key="KokoPurple"  Color="#818CF8"/>
                            <SolidColorBrush x:Key="KokoPink"    Color="#F472B6"/>
                            <SolidColorBrush x:Key="KokoGold"    Color="#F59E0B"/>
                            <SolidColorBrush x:Key="KokoCyan"    Color="#22D3EE"/>
                            <SolidColorBrush x:Key="KokoRed"     Color="#EF4444"/>
                            <SolidColorBrush x:Key="KokoOrange"  Color="#F97316"/>
                            <SolidColorBrush x:Key="KokoGreen"   Color="#22C55E"/>
                            <SolidColorBrush x:Key="DashPanelBg"     Color="#131318"/>
                            <SolidColorBrush x:Key="DashPanelBorder" Color="#2A2A35"/>
                            <SolidColorBrush x:Key="DashMuted"       Color="#6B6B80"/>
                            <SolidColorBrush x:Key="DashVeryMuted"   Color="#3A3A4E"/>
                            <Style x:Key="DashSecHdr" TargetType="TextBlock">
                                <Setter Property="FontSize"   Value="10"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Foreground" Value="#6B6B80"/>
                                <Setter Property="Margin"     Value="0,0,0,8"/>
                            </Style>
                            <Style x:Key="DashPanel" TargetType="Border">
                                <Setter Property="Background"      Value="{StaticResource DashPanelBg}"/>
                                <Setter Property="BorderBrush"     Value="{StaticResource DashPanelBorder}"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="CornerRadius"    Value="8"/>
                                <Setter Property="Padding"         Value="16,14"/>
                            </Style>
                            <Style x:Key="DashSmallLabel" TargetType="TextBlock">
                                <Setter Property="FontSize"   Value="9"/>
                                <Setter Property="Foreground" Value="#6B6B80"/>
                            </Style>
                            <Style x:Key="DashTabBtn" TargetType="Border">
                                <Setter Property="Padding"      Value="16,6"/>
                                <Setter Property="CornerRadius" Value="6"/>
                                <Setter Property="Cursor"       Value="Hand"/>
                                <Setter Property="Background"   Value="Transparent"/>
                            </Style>
                            <Style x:Key="DashTabText" TargetType="TextBlock">
                                <Setter Property="FontSize"          Value="11"/>
                                <Setter Property="FontWeight"        Value="SemiBold"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Foreground"        Value="#6B6B80"/>
                            </Style>
                        </Grid.Resources>

                        <Grid Margin="14,10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="50"/>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="24"/>
                            </Grid.RowDefinitions>

                            <!-- HEADER -->
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Dashboard" FontSize="16" FontWeight="SemiBold"
                                                   Foreground="#E0E0EE"/>
                                        <TextBlock Text="Cognitive workspace" FontSize="10"
                                                   Foreground="{StaticResource DashMuted}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock x:Name="DashCurrentMoodDisplay" Text="CALM"
                                               FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center">
                                        <TextBlock.Foreground><SolidColorBrush Color="#22D3EE"/></TextBlock.Foreground>
                                    </TextBlock>
                                    <TextBlock x:Name="DashMoodSubtext" Text="" FontSize="9" Foreground="{StaticResource DashMuted}"
                                               HorizontalAlignment="Center" Margin="0,3,0,0" FontStyle="Italic"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <TextBlock x:Name="DashClockText" Text="00:00" FontSize="20"
                                               Foreground="{StaticResource KokoGold}" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                    <TextBlock x:Name="DashDateText" Text="" FontSize="8"
                                               Foreground="{StaticResource DashMuted}" HorizontalAlignment="Right"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                                        <Border x:Name="HeartDot" Width="10" Height="10" CornerRadius="5"
                                                Background="#FF4D6D" Margin="0,0,6,0"
                                                ToolTip="Heart rate" VerticalAlignment="Center"
                                                RenderTransformOrigin="0.5,0.5">
                                            <Border.RenderTransform>
                                                <ScaleTransform x:Name="HeartScale" ScaleX="1" ScaleY="1"/>
                                            </Border.RenderTransform>
                                            <Border.Effect>
                                                <DropShadowEffect Color="#FF4D6D" BlurRadius="8" ShadowDepth="0" Opacity="0.6"/>
                                            </Border.Effect>
                                        </Border>
                                        <TextBlock x:Name="HeartBpmText" Text="-- bpm"
                                                   Foreground="#C8C8D0" FontFamily="Consolas" FontSize="11"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                            <!-- TAB SELECTOR -->
                            <Grid Grid.Row="1" VerticalAlignment="Center">
                                <Border HorizontalAlignment="Left" VerticalAlignment="Center"
                                        Background="#0E0E18" BorderBrush="#1E1E2E" BorderThickness="1"
                                        CornerRadius="8" Padding="3">
                                    <StackPanel Orientation="Horizontal">
                                        <Border x:Name="DashTabNeuroBtn" Style="{StaticResource DashTabBtn}"
                                                MouseDown="DashTabNeuro_Click">
                                            <TextBlock Text="Neural" Style="{StaticResource DashTabText}"/>
                                        </Border>
                                        <Border x:Name="DashTabDevBtn" Style="{StaticResource DashTabBtn}"
                                                MouseDown="DashTabDev_Click">
                                            <TextBlock Text="Dev" Style="{StaticResource DashTabText}"/>
                                        </Border>
                                        <Border x:Name="DashTabMemoryBtn" Style="{StaticResource DashTabBtn}"
                                                MouseDown="DashTabMemory_Click">
                                            <TextBlock Text="Memory" Style="{StaticResource DashTabText}"/>
                                        </Border>
                                        <Border x:Name="DashTabSystemBtn" Style="{StaticResource DashTabBtn}"
                                                MouseDown="DashTabSystem_Click">
                                            <TextBlock Text="System" Style="{StaticResource DashTabText}"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                                <TextBlock x:Name="DashTabSubtitle" Text=""
                                           FontSize="9" Foreground="{StaticResource DashMuted}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>

                            <!-- BODY -->
                            <Grid Grid.Row="2" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="5"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- NEURO PANEL -->
                                <Grid x:Name="DashNeuroPanel" Grid.Column="0" Visibility="Visible">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="220"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="150"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="86"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="170"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="160"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="3*"/>
                                            <ColumnDefinition Width="6"/>
                                            <ColumnDefinition Width="180"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Style="{StaticResource DashPanel}">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="18"/>
                                                </Grid.RowDefinitions>
                                                <Grid Grid.Row="0" Margin="0,0,0,6">
                                                    <TextBlock Text="АКТИВНІСТЬ ПО ГОДИНАХ // КОЛИ ВСЕ ТУТ"
                                                               Style="{StaticResource DashSecHdr}" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="DashActivitySparkLabel" HorizontalAlignment="Right"
                                                               FontSize="8" Foreground="{StaticResource KokoGreen}" VerticalAlignment="Center">
                                                        <TextBlock.Effect>
                                                            <DropShadowEffect Color="#00FF88" ShadowDepth="0" BlurRadius="6" Opacity="0.5"/>
                                                        </TextBlock.Effect>
                                                    </TextBlock>
                                                </Grid>
                                                <Canvas x:Name="DashActivityBarCanvas" Grid.Row="1" ClipToBounds="True"/>
                                                <Canvas x:Name="DashActivityAxisCanvas" Grid.Row="2" Height="18"/>
                                            </Grid>
                                        </Border>
                                        <Border Grid.Column="2" Style="{StaticResource DashPanel}">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock Grid.Row="0" Text="ЕМОЦІЇ (7 ДНІВ)" Style="{StaticResource DashSecHdr}"/>
                                                <Grid Grid.Row="1">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>
                                                    <Grid Grid.Row="0" HorizontalAlignment="Center">
                                                        <Canvas x:Name="DashEmotionPieCanvas" Width="120" Height="120"/>
                                                        <TextBlock x:Name="DashPieCenterLabel" Text=""
                                                                   FontSize="8" FontWeight="Bold" Foreground="White"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                   IsHitTestVisible="False"/>
                                                    </Grid>
                                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                                                  HorizontalScrollBarVisibility="Disabled">
                                                        <StackPanel x:Name="DashPieLegendPanel" Margin="0,6,0,0"/>
                                                    </ScrollViewer>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </Grid>

                                    <Border Grid.Row="2" Style="{StaticResource DashPanel}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="16"/>
                                            </Grid.RowDefinitions>
                                            <Grid Grid.Row="0" Margin="0,0,0,6">
                                                <TextBlock Text="КРИВА ТРАЄКТОРІЯ // НІТИМУ ДО БЛИЗОСТІ"
                                                           Style="{StaticResource DashSecHdr}" VerticalAlignment="Center"/>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                    <Ellipse Width="7" Height="7" Fill="{StaticResource KokoPink}"
                                                             Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="actual" FontSize="7" Foreground="{StaticResource KokoPink}"
                                                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <Rectangle Width="8" Height="1.5" Fill="{StaticResource DashMuted}"
                                                               Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="baseline" FontSize="7" Foreground="{StaticResource DashMuted}"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Grid>
                                            <Canvas x:Name="DashBurndownCanvas" Grid.Row="1" ClipToBounds="True"/>
                                            <Canvas x:Name="DashBurndownAxisCanvas" Grid.Row="2" Height="16"/>
                                        </Grid>
                                    </Border>

                                    <!-- KPI Cards -->
                                    <Grid Grid.Row="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="6"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="6"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="6"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Style="{StaticResource DashPanel}">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="22"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock Grid.Row="0" Text="Connection" Style="{StaticResource DashSmallLabel}" Margin="0,0,0,2"/>
                                                <Grid Grid.Row="1">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock x:Name="DashKpiConnection" Text="50%"
                                                               FontSize="24" FontWeight="Bold" Foreground="{StaticResource KokoPink}"/>
                                                    <TextBlock x:Name="DashKpiConnectionDelta" Grid.Column="1"
                                                               FontSize="8" Foreground="{StaticResource KokoGreen}"
                                                               VerticalAlignment="Bottom" Margin="4,0,0,2"/>
                                                </Grid>
                                                <TextBlock Grid.Row="2" x:Name="DashKpiBondLabel" Text="KNOWN"
                                                           FontSize="7" Foreground="{StaticResource DashMuted}" Margin="0,1,0,0"/>
                                                <Canvas Grid.Row="3" x:Name="DashKpiSparkConnection" Height="22"/>
