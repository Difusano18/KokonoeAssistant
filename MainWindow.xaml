                                </StackPanel>
                            </ScrollViewer>

                            <Border Grid.Row="2" BorderBrush="{DynamicResource AccentBgBorder2}"
                                    BorderThickness="0,1,0,0" Margin="14,0,14,0" Padding="0,8">
                                <StackPanel>
                                    <TextBlock Text="// STATE / VISION" FontSize="8" FontFamily="Consolas"
                                               Foreground="{DynamicResource AccentDim}" Margin="0,0,0,5"/>
                                    <UniformGrid Columns="2" Margin="0,0,0,6">
                                        <StackPanel Margin="0,0,8,5">
                                            <TextBlock Text="screen" FontSize="8" FontFamily="Consolas" Foreground="{DynamicResource AccentDim}"/>
                                            <TextBlock x:Name="RightScreenModeText" Text="вЂ”" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource AccentBase}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,5">
                                            <TextBlock Text="vision" FontSize="8" FontFamily="Consolas" Foreground="{DynamicResource AccentDim}"/>
                                            <TextBlock x:Name="RightVisionStatusText" Text="вЂ”" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource AccentPrimary}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,8,0">
                                            <TextBlock Text="state" FontSize="8" FontFamily="Consolas" Foreground="{DynamicResource AccentDim}"/>
                                            <TextBlock x:Name="RightStateRefreshText" Text="вЂ”" FontSize="9" Foreground="{DynamicResource AccentText}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="proactive" FontSize="8" FontFamily="Consolas" Foreground="{DynamicResource AccentDim}"/>
                                            <TextBlock x:Name="RightProactiveText" Text="вЂ”" FontSize="9" Foreground="{DynamicResource AccentText}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </UniformGrid>
                                    <TextBlock Text="active intents" FontSize="8" FontFamily="Consolas"
                                               Foreground="{DynamicResource AccentDim}" Margin="0,2,0,4"/>
                                    <ItemsControl x:Name="DashCuriosityList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" Foreground="{DynamicResource AccentBase}"
                                                           FontSize="8" TextWrapping="Wrap" Margin="0,0,0,3">
                                                    <TextBlock.Effect>
                                                        <DropShadowEffect Color="#68E6D6" ShadowDepth="0" BlurRadius="5" Opacity="0.28"/>
                                                    </TextBlock.Effect>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="3" BorderBrush="{DynamicResource AccentBgBorder2}"
                                    BorderThickness="0,1,0,0" Margin="14,0,14,0" Padding="0,8,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="bond" FontSize="8" FontFamily="Consolas"
                                                   Foreground="{DynamicResource AccentDim}"/>
                                        <TextBlock x:Name="DashSideBondLabel" Text="KNOWN"
                                                   FontSize="11" FontWeight="Bold"
                                                   Foreground="{DynamicResource AccentBase}"/>
                                        <TextBlock x:Name="DashSideAttachmentText" Text="trust -- В· intimacy --"
                                                   FontSize="8" FontFamily="Consolas"
                                                   Foreground="{DynamicResource AccentDim}" TextWrapping="Wrap"
                                                   Margin="0,2,0,0"/>
                                        <TextBlock x:Name="DashSideBondDirectiveText" Text="contract -"
                                                   FontSize="8" FontFamily="Consolas"
                                                   Foreground="{DynamicResource AccentBase}" TextWrapping="Wrap"
                                                   Margin="0,5,0,0"/>
                                        <TextBlock x:Name="RightVaultDoctorText" Text="vault doctor -"
                                                   FontSize="8" FontFamily="Consolas"
                                                   Foreground="{DynamicResource AccentMuted}" TextWrapping="Wrap"
                                                   Margin="0,5,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                        <TextBlock Text="connection" FontSize="8" FontFamily="Consolas"
                                                   Foreground="{DynamicResource AccentDim}" HorizontalAlignment="Right"/>
                                        <TextBlock x:Name="DashSideConnValue" Text="50%"
                                                   FontSize="18" FontWeight="Bold"
                                                   Foreground="{DynamicResource AccentPrimary}" HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Operator Console Panel -->
                    <Border Grid.Row="1" Background="{DynamicResource KokoSidebarBrush}"
                            BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="1,1,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Padding="14,9,14,7"
                                    BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="0,0,0,1">
                                <Grid>
                                    <TextBlock Text="OPERATOR CONSOLE" FontSize="9" FontFamily="Consolas"
                                               Foreground="{DynamicResource AccentBase}" VerticalAlignment="Center"/>
                                    <Ellipse Width="5" Height="5" Fill="{DynamicResource Brush_Ok}"
                                             HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <WrapPanel Grid.Row="1" Margin="10,6,10,4">
                                <Button Content="Health"    Style="{StaticResource BtnGhost}" Padding="7,3" Margin="2" Click="RightVaultDoctor_Click"/>
                                <Button Content="Inspector" Style="{StaticResource BtnGhost}" Padding="7,3" Margin="2" Click="RightInspector_Click"/>
                                <Button Content="Genesis"  Style="{StaticResource BtnGhost}" Padding="7,3" Margin="2" Click="RightGenesis_Click"/>
                                <Button Content="Overlord" Style="{StaticResource BtnGhost}" Padding="7,3" Margin="2" Click="RightOverlord_Click"/>
                                <Button Content="Graph"     Style="{StaticResource BtnGhost}" Padding="7,3" Margin="2" Click="McpBuildGraph_Click"/>
                                <Button Content="Visual"    Style="{StaticResource BtnGhost}" Padding="7,3" Margin="2" Click="OpenKnowledgeGraph_Click"/>
                                <Button Content="Sync"      Style="{StaticResource BtnGhost}" Padding="7,3" Margin="2" Click="McpSyncNotes_Click"/>
                            </WrapPanel>

                            <Border Grid.Row="2" Background="{DynamicResource KokoCardBrush}"
                                    BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="1"
                                    Margin="10,0,10,10" CornerRadius="8" Padding="8">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <TextBlock x:Name="McpOutput" Foreground="{DynamicResource AccentMuted}"
                                               FontSize="9" FontFamily="Consolas" TextWrapping="Wrap"/>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

            </Grid>

            <!-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ STATUS BAR в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ -->
            <Border Grid.Row="2" Background="{DynamicResource AccentBgBase}"
                    BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="0,1,0,0">
                <Grid Margin="14,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="5" Height="5" Fill="{DynamicResource Brush_Ok}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock x:Name="StatusCoreLabel" Text="core.online"
                                   FontSize="9" FontFamily="Consolas" Foreground="{DynamicResource AccentDim}"
                                   VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <Ellipse Width="5" Height="5" Fill="{DynamicResource AccentDim}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="obsidian.sync" FontSize="9" FontFamily="Consolas"
                                   Foreground="{DynamicResource AccentDim}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <TextBlock x:Name="StatusBpm" Text="-- bpm"
                                   FontSize="9" FontFamily="Consolas" Foreground="{DynamicResource AccentDim}"
                                   VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <TextBlock x:Name="StatusMood" Text=""
                                   FontSize="9" FontFamily="Consolas" Foreground="{DynamicResource AccentDim}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="ThoughtStreamStatusText" Grid.Column="1"
                               Text="agent: idle"
                               FontSize="9" FontFamily="Consolas"
                               Foreground="{DynamicResource AccentBase}"
                               VerticalAlignment="Center"
                               Margin="18,0,18,0"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="StatusTimestamp" Grid.Column="2" Text=""
                               FontSize="9" FontFamily="Consolas" Foreground="{DynamicResource AccentDim}"
                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ LOADING OVERLAY в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ -->
            <Grid x:Name="LoadingOverlay" Grid.RowSpan="3"
                  Background="{DynamicResource AccentBgMain}" Panel.ZIndex="100">

                <Grid.Triggers>
                    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                <DoubleAnimation Storyboard.TargetName="GlowRing"
                                                 Storyboard.TargetProperty="Opacity"
                                                 From="0.10" To="0.38" Duration="0:0:2.2">
                                    <DoubleAnimation.EasingFunction>
                                        <SineEase EasingMode="EaseInOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="GlowScaleX"
                                                 Storyboard.TargetProperty="ScaleX"
                                                 From="0.90" To="1.10" Duration="0:0:2.2">
                                    <DoubleAnimation.EasingFunction>
                                        <SineEase EasingMode="EaseInOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="GlowScaleX"
                                                 Storyboard.TargetProperty="ScaleY"
                                                 From="0.90" To="1.10" Duration="0:0:2.2">
                                    <DoubleAnimation.EasingFunction>
                                        <SineEase EasingMode="EaseInOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Grid.Triggers>

                <!-- Matrix rain canvas вЂ” hidden but kept for code-behind -->
                <Canvas x:Name="MatrixCanvas" Visibility="Collapsed"/>

                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                    <!-- Pulsing accent ring -->
                    <Grid HorizontalAlignment="Center" Margin="0,0,0,32" Width="72" Height="72">
                        <Ellipse x:Name="GlowRing" Width="72" Height="72"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                 Opacity="0.15">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="{DynamicResource AccentBaseColor}" Offset="0"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                            <Ellipse.RenderTransform>
                                <ScaleTransform x:Name="GlowScaleX" CenterX="36" CenterY="36"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        <Ellipse Width="48" Height="48" HorizontalAlignment="Center" VerticalAlignment="Center"
                                 Stroke="{DynamicResource AccentBase}" StrokeThickness="2" Opacity="0.4"/>
                        <TextBlock Text="в—€" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{DynamicResource AccentBase}"/>
                    </Grid>

                    <!-- App name -->
                    <TextBlock Text="Kokonoe" FontSize="22" FontWeight="SemiBold"
                               Foreground="#E0E0EE" FontFamily="Segoe UI Variable, Segoe UI"
                               HorizontalAlignment="Center" Margin="0,0,0,4"/>

                    <TextBlock Text="Initializing workspace..." FontSize="11"
                               Foreground="#3A3A4E" FontFamily="Segoe UI Variable, Segoe UI"
                               HorizontalAlignment="Center" Margin="0,0,0,34"/>

                    <!-- Progress bar -->
                    <Border Width="260" Height="2" Background="#1A1A22"
                            CornerRadius="1" HorizontalAlignment="Center" Margin="0,0,0,12">
                        <Border x:Name="LoadingBar" HorizontalAlignment="Left"
                                Width="0" Height="2" Background="{DynamicResource AccentBase}" CornerRadius="1"/>
                    </Border>

                    <!-- Status text -->
                    <TextBlock x:Name="LoadingStatus" Text="loading..."
                               FontSize="10" Foreground="#3A3A4E"
                               FontFamily="Segoe UI Variable, Segoe UI"
                               HorizontalAlignment="Center" Margin="0,0,0,36"/>

                    <!-- Generated greeting preview -->
                    <Border x:Name="GreetingPreviewBorder" Visibility="Collapsed"
                            MaxWidth="480" Background="#131318"
                            BorderBrush="#2A2A35" BorderThickness="1"
                            CornerRadius="10" Padding="20,15">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,9">
                                <Ellipse Width="8" Height="8" Fill="{DynamicResource AccentBase}"
                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Kokonoe" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentBase}"/>
                            </StackPanel>
                            <TextBlock x:Name="GreetingPreviewText"
                                       TextWrapping="Wrap" FontSize="13"
                                       Foreground="#C0C0D4" FontFamily="Segoe UI Variable, Segoe UI"
                                       LineHeight="22"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Grid>

            <Border x:Name="KokoNoticeBorder" Grid.RowSpan="3"
                    Width="360" HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,52,22,0" Padding="14,12"
                    Background="#E90A1020" BorderBrush="{DynamicResource AccentBase}"
                    BorderThickness="1" CornerRadius="10"
                    Visibility="Collapsed" Opacity="0"
                    Panel.ZIndex="999">
                <Border.Effect>
                    <DropShadowEffect Color="#68E6D6" ShadowDepth="0" BlurRadius="20" Opacity="0.35"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock x:Name="KokoNoticeTitle" Text="Kokonoe"
                               FontSize="11" FontWeight="Bold" FontFamily="Consolas"
                               Foreground="{DynamicResource AccentBase}"/>
                    <TextBlock x:Name="KokoNoticeText" Text=""
                               Margin="0,4,0,0" FontSize="12"
                               Foreground="{DynamicResource AccentTextLight}"
                               TextWrapping="Wrap" MaxHeight="70"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Border>

        </Grid>
    </Border>
</Window>
