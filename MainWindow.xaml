<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="KokonoeAssistant.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:KokonoeAssistant.Controls"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:skia="clr-namespace:SkiaSharp.Views.WPF;assembly=SkiaSharp.Views.WPF"
        Title="Kokonoe" Height="900" Width="1380"
        MinHeight="640" MinWidth="980"
        Background="{DynamicResource AccentBgMain}"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="Manual"
        Loaded="Window_Loaded"
        Icon="Logo/Logo_icon.ico">

    <Window.TaskbarItemInfo>
        <shell:TaskbarItemInfo x:Name="KokoTaskbarInfo"/>
    </Window.TaskbarItemInfo>

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome ResizeBorderThickness="6" CaptionHeight="0"
                            GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>

        <!-- в”Ђв”Ђв”Ђ SCROLLBAR в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ -->
        <Style x:Key="KokoScrollThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{DynamicResource AccentScrollThm}" CornerRadius="2"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource KokoScrollThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Button/Input/Nav styles live in App.xaml -->

        <!-- в”Ђв”Ђв”Ђ LISTBOX в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ -->
        <Style x:Key="CleanListBox" TargetType="ListBox">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>
        <Style x:Key="CleanListItem" TargetType="ListBoxItem">
            <Setter Property="Background"                 Value="Transparent"/>
            <Setter Property="BorderThickness"            Value="0"/>
            <Setter Property="Padding"                    Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentNavBg}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentListHovBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="KokoGlassPanel" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource KokoCardBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBgBorder2}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="0" Opacity="0.46"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- в”Ђв”Ђв”Ђ HEALTH SLIDER в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ -->
        <Style x:Key="HealthSlider" TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" Background="{DynamicResource AccentPrimary}" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" Background="{DynamicResource AccentAsstBorder}" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Width="14" Height="14" Background="{DynamicResource AccentBase}"
                                                        CornerRadius="7" BorderBrush="{DynamicResource AccentVeryLight}" BorderThickness="1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ ROOT в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ -->
    <Border Background="{DynamicResource KokoWindowBackground}"
            BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="1"
            CornerRadius="10" Margin="8"
            ClipToBounds="True">

        <Grid x:Name="RootGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="42"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="22"/>
            </Grid.RowDefinitions>

            <controls:NeuralParticleBackground Grid.RowSpan="3" Opacity="0.08" IsAnimated="False"/>

            <!-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ TITLE BAR в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ -->
            <Border Grid.Row="0" Background="{DynamicResource KokoHeaderBrush}"
                    BorderBrush="{DynamicResource AccentBgBorder1}" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Logo -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="14,0,0,0">
                        <Ellipse x:Name="EmotionDot" Width="8" Height="8" Margin="0,0,10,0"
                                 VerticalAlignment="Center" Fill="{DynamicResource AccentBase}">
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#5CB7AA" BlurRadius="8" ShadowDepth="0" Opacity="0.50"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <TextBlock Text="KOKONOE" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentTextLight}" FontFamily="Segoe UI Variable, Segoe UI"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text=" / workspace" FontSize="11"
                                   Foreground="{DynamicResource AccentDim}" FontFamily="Segoe UI Variable, Segoe UI"
                                   VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </StackPanel>

                    <!-- drag area -->
                    <Border Grid.Column="1" Padding="18,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Border Background="{DynamicResource KokoSurfaceInsetBrush}"
                                    BorderBrush="{DynamicResource AccentBgBorder}" BorderThickness="1"
                                    CornerRadius="7" Padding="10,4">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="6" Height="6" Fill="{DynamicResource Brush_Ok}" Margin="0,0,7,0"
                                             VerticalAlignment="Center"/>
                                    <TextBlock Text="LOCAL RUNTIME" FontSize="10" FontFamily="Consolas"
                                               Foreground="{DynamicResource AccentMuted}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Window controls -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="0,0,8,0">
                        <Button x:Name="ExportChatBtn" Content="&#x25A3;" Style="{StaticResource ChromeBtn}"
                                Click="ExportChat_Click" ToolTip="Export chat"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button x:Name="ClearChatBtn" Content="&#x232B;" Style="{StaticResource ChromeBtn}"
                                Click="ClearChat_Click" ToolTip="Clear chat"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Border Width="1" Background="{DynamicResource AccentBgBorder}" Margin="6,7"/>
                        <Button Content="-" Style="{StaticResource ChromeBtn}" Click="MinimizeBtn_Click"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button Content="&#x25A1;" Style="{StaticResource ChromeBtn}" Click="MaximizeBtn_Click"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button Content="x" Click="CloseBtn_Click"
                                Width="30" Height="30" Cursor="Hand" BorderThickness="0"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                Background="Transparent" Foreground="{DynamicResource Brush_3A2020}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource Brush_2A0808}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource Brush_FF5555}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ BODY в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ -->
            <Grid x:Name="BodyGrid" Grid.Row="1" SizeChanged="BodyGrid_SizeChanged">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="232"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- в”Ђв”Ђв”Ђ LEFT NAV в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ -->
                <Border Grid.Column="0" Background="{DynamicResource KokoSidebarBrush}"
                        BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Sidebar header -->
                        <Border Grid.Row="0" Padding="18,16,18,14"
                                Background="{DynamicResource KokoSurfaceInsetBrush}"
                                BorderBrush="{DynamicResource AccentBgBorder}" BorderThickness="0,0,0,1">
                            <StackPanel>
                                <TextBlock Text="WORKSPACE" FontSize="9" FontFamily="Consolas"
                                           Foreground="{DynamicResource AccentDim}"/>
                                <TextBlock Text="Assistant console" FontSize="13" FontWeight="SemiBold"
                                           FontFamily="Segoe UI Variable, Segoe UI"
                                           Foreground="{DynamicResource AccentTextLight}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Nav items -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                          <StackPanel Margin="12,10,12,0">

                            <Button x:Name="TabBtnChat" Style="{StaticResource BtnNavActive}" Click="Tab_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x25CC;" FontSize="14" VerticalAlignment="Center" Width="18"/>
                                    <TextBlock Text="Chat" FontSize="11" VerticalAlignment="Center"
                                               FontFamily="Segoe UI Variable, Segoe UI" Margin="8,0,0,0"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="TabBtnVault" Style="{StaticResource BtnNav}" Click="Tab_Click" Visibility="Collapsed" IsEnabled="False">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x25A3;" FontSize="13" VerticalAlignment="Center" Width="18"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="TabBtnHealth" Style="{StaticResource BtnNav}" Click="Tab_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x25A6;" FontSize="13" VerticalAlignment="Center" Width="18"/>
                                    <TextBlock Text="Calendar" FontSize="11" VerticalAlignment="Center"
                                               FontFamily="Segoe UI Variable, Segoe UI" Margin="8,0,0,0"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="TabBtnTools" Style="{StaticResource BtnNav}" Click="Tab_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x25C8;" FontSize="13" VerticalAlignment="Center" Width="18"/>
                                        <TextBlock Text="Dashboard" FontSize="11" VerticalAlignment="Center"
                                               FontFamily="Segoe UI Variable, Segoe UI" Margin="8,0,0,0"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="TabBtnMemory" Style="{StaticResource BtnNav}" Click="Tab_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x25C7;" FontSize="13" VerticalAlignment="Center" Width="18"/>
                                        <TextBlock Text="Memory" FontSize="11" VerticalAlignment="Center"
                                               FontFamily="Segoe UI Variable, Segoe UI" Margin="8,0,0,0"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="TabBtnPulse" Style="{StaticResource BtnNav}" Click="Tab_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x2665;" FontSize="13" VerticalAlignment="Center" Width="18"
                                               Foreground="{DynamicResource RgbRedBrush}"/>
                                    <TextBlock Text="Pulse" FontSize="11" VerticalAlignment="Center"
                                               FontFamily="Segoe UI Variable, Segoe UI" Margin="8,0,0,0"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="TabBtnVoice" Style="{StaticResource BtnNav}" Click="Tab_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x25C9;" FontSize="13" VerticalAlignment="Center" Width="18"/>
                                    <TextBlock Text="Voice" FontSize="11" VerticalAlignment="Center"
                                               FontFamily="Segoe UI Variable, Segoe UI" Margin="8,0,0,0"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="TabBtnSandbox" Style="{StaticResource BtnNav}" Click="Tab_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x2B21;" FontSize="13" VerticalAlignment="Center" Width="18"/>
                                    <TextBlock Text="Sandbox" FontSize="11" VerticalAlignment="Center"
                                               FontFamily="Segoe UI Variable, Segoe UI" Margin="8,0,0,0"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="TabBtnTelegram" Style="{StaticResource BtnNav}" Click="Tab_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x2708;" FontSize="13" VerticalAlignment="Center" Width="18"/>
                                    <TextBlock Text="Telegram" FontSize="11" VerticalAlignment="Center"
                                               FontFamily="Segoe UI Variable, Segoe UI" Margin="8,0,0,0"/>
                                </StackPanel>
                            </Button>

                            <!-- DIAGNOSTICS section -->
                            <Border Margin="0,16,0,8" BorderBrush="{DynamicResource AccentBgBorder}" BorderThickness="0,1,0,0" Padding="0,10,0,0">
                                <TextBlock Text="DIAGNOSTICS" FontSize="9" FontFamily="Consolas"
                                           Foreground="{DynamicResource AccentDim}"/>
                            </Border>

                            <StackPanel Margin="0,0,0,4">
                                <StackPanel.Resources>
                                    <Style TargetType="Grid">
                                        <Setter Property="Margin" Value="0,0,0,6"/>
                                    </Style>
                                </StackPanel.Resources>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse x:Name="DiagCoreDot" Width="7" Height="7" Fill="{DynamicResource Brush_Ok}"
                                             VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="core.online" FontSize="9" FontFamily="Consolas"
                                               Foreground="{DynamicResource AccentMuted}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse x:Name="DiagTgDot" Width="7" Height="7" Fill="{DynamicResource AccentDim}"
                                             VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="mtproto" FontSize="9" FontFamily="Consolas"
                                               Foreground="{DynamicResource AccentDim}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse x:Name="DiagObsidianDot" Width="7" Height="7" Fill="{DynamicResource AccentDim}"
                                             VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="obsidian" FontSize="9" FontFamily="Consolas"
                                               Foreground="{DynamicResource AccentDim}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                </Grid>
                            </StackPanel>

                          </StackPanel>
                        </ScrollViewer>

                        <!-- Sidebar footer -->
                        <Border Grid.Row="2" Background="{DynamicResource KokoSurfaceInsetBrush}"
                                BorderBrush="{DynamicResource AccentBgBorder}" BorderThickness="0,1,0,0"
                                Padding="16,12,16,14">
                            <StackPanel>
                                <TextBlock Text="SESSION" FontSize="9" FontFamily="Consolas"
                                           Foreground="{DynamicResource AccentDim}" Margin="0,0,0,8"/>
                                <Grid>
                                    <TextBlock Text="RAM" FontSize="8" FontFamily="Consolas" Foreground="{DynamicResource AccentDim}"/>
                                    <TextBlock x:Name="SideFootRam" Text="--" HorizontalAlignment="Right"
                                               FontSize="9" FontFamily="Consolas" Foreground="{DynamicResource AccentText}"/>
                                </Grid>
                                <Grid Margin="0,4,0,0">
                                    <TextBlock Text="UPTIME" FontSize="8" FontFamily="Consolas" Foreground="{DynamicResource AccentDim}"/>
                                    <TextBlock x:Name="SideFootUptime" Text="--" HorizontalAlignment="Right"
                                               FontSize="9" FontFamily="Consolas" Foreground="{DynamicResource AccentText}"/>
                                </Grid>
                                <Grid Margin="0,4,0,0">
                                    <TextBlock Text="BUILD" FontSize="8" FontFamily="Consolas" Foreground="{DynamicResource AccentDim}"/>
                                    <TextBlock Text="2026.04" HorizontalAlignment="Right"
                                               FontSize="9" FontFamily="Consolas" Foreground="{DynamicResource AccentMuted}"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- в”Ђв”Ђв”Ђ MAIN CONTENT в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ -->
                <Grid Grid.Column="1">

                    <!-- в•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ CHAT TAB в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•— -->
                    <Grid x:Name="ChatTab" Background="Transparent">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Live state strip -->
                        <Border Grid.Row="0" Background="{DynamicResource KokoSurfaceRaisedBrush}"
                                BorderBrush="{DynamicResource AccentBgBorder}" BorderThickness="0,0,0,1"
                                Padding="20,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.15*"/>
                                    <ColumnDefinition Width="1.1*"/>
                                    <ColumnDefinition Width="0.85*"/>
                                    <ColumnDefinition Width="1.25*"/>
                                    <ColumnDefinition Width="1.1*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Grid.ColumnSpan="5" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Background="{DynamicResource KokoSurfaceInsetBrush}"
                                            BorderBrush="{DynamicResource AccentBgBorder}" BorderThickness="1"
                                            CornerRadius="7" Padding="8,3" Margin="0,0,10,0">
                                        <TextBlock Text="LIVE" FontSize="9" FontFamily="Consolas"
                                                   Foreground="{DynamicResource AccentBase}"/>
                                    </Border>
                                    <TextBlock x:Name="LiveCoreCompactText"
                                               Text="Kokonoe - loading - vault -- - vision --"
                                               FontSize="11" FontFamily="Consolas" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentTextLight}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="0" Margin="0,0,12,0" Visibility="Collapsed">
                                    <TextBlock Text="Р–РР’Р• РЇР”Р Рћ" FontSize="9" FontFamily="Consolas" FontWeight="Bold"
                                               Foreground="{DynamicResource AccentBase}"/>
                                    <TextBlock x:Name="LiveCoreEmotionText" Text="РµРјРѕС†С–СЏ: Р·Р°РІР°РЅС‚Р°Р¶РµРЅРЅСЏ"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentTextLight}" Margin="0,3,0,0"
                                               TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                                    <TextBlock x:Name="LiveCoreBondText" Text="Р·РІ'СЏР·РѕРє -- | СЃРёР»Р° --"
                                               FontSize="10" Foreground="{DynamicResource Brush_8AC8A0}"
                                               TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="0,0,12,0" Visibility="Collapsed">
                                    <TextBlock Text="РўР†Р›Рћ" FontSize="9" FontFamily="Consolas" FontWeight="Bold"
                                               Foreground="{DynamicResource AccentBase}"/>
                                    <TextBlock x:Name="LiveCoreBodyText" Text="СЃРѕРјР°С‚РёРєР°: Р·Р°РІР°РЅС‚Р°Р¶РµРЅРЅСЏ"
