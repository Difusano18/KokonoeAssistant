                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="22"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="В·" Foreground="{DynamicResource AccentBase}" Margin="0,0,6,0"/>
                                                            <TextBlock Text="{Binding TimeStr}" Foreground="{DynamicResource Brush_2A6040}"
                                                                       FontFamily="Consolas" FontSize="11" Margin="0,0,8,0"/>
                                                            <TextBlock Text="{Binding Title}" Foreground="{DynamicResource AccentMuted}" FontSize="12"/>
                                                        </StackPanel>
                                                        <Button Grid.Column="1" Content="Г—" Tag="{Binding Id}"
