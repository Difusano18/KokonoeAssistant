                                    <TextBlock x:Name="LiveCoreMemoryText" Text="СЃРёРЅС…СЂРѕРЅС–Р·Р°С†С–СЏ --"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentTextLight}" Margin="0,3,0,0"
                                               TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                                    <TextBlock x:Name="LiveCoreVaultText" Text="РѕРіР»СЏРґ -- | Р·Р°РґР°С‡С– --"
                                               FontSize="10" Foreground="{DynamicResource Brush_8AC8A0}"
                                               TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxHeight="32"
                                               ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
