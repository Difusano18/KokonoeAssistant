                                </Border>
                                <Border Grid.Row="1" Background="{DynamicResource Brush_050D07}"
                                        BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="0,0,0,1" Padding="12,8">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="РћРџР•Р РђР¦Р†Р‡ РџРђРњ'РЇРўР†" FontSize="9" FontWeight="Bold"
                                                           Foreground="{DynamicResource AccentBase}" FontFamily="Consolas"/>
                                                <TextBlock x:Name="MemoryOpsStatusLabel" Text="РЅРµ Р·Р°РІР°РЅС‚Р°Р¶РµРЅРѕ"
                                                           FontSize="10" Foreground="{DynamicResource Brush_8AC8A0}" Margin="0,2,0,0"/>
                                                <TextBlock x:Name="MemoryOpsDetailLabel" Text=""
                                                           FontSize="9" Foreground="{DynamicResource Brush_1A3020}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <WrapPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                <Button Content="РћРЅРѕРІРёС‚Рё" Style="{StaticResource BtnGhost}" Padding="8,4" Margin="4,0,0,0"
                                                        Click="MemoryOpsRefresh_Click"/>
                                                <Button Content="РџРµСЂРµРіР»СЏРґ С‡РёСЃС‚РєРё" Style="{StaticResource BtnGhost}" Padding="8,4" Margin="4,0,0,0"
                                                        Click="MemoryOpsPreviewCleanup_Click"/>
                                                <Button Content="Р—Р°СЃС‚РѕСЃСѓРІР°С‚Рё С‡РёСЃС‚РєСѓ" Style="{StaticResource BtnGhost}" Padding="8,4" Margin="4,0,0,0"
                                                        Click="MemoryOpsApplyCleanup_Click"/>
                                            </WrapPanel>
                                        </Grid>
                                        <WrapPanel Grid.Row="1" Margin="0,8,0,0">
                                            <Button Content="РЇРєС–СЃС‚СЊ" Style="{StaticResource BtnGhost}" Padding="8,4" Margin="0,0,4,0"
                                                    Click="OpenMemoryQuality_Click"/>
                                            <Button Content="РћРіР»СЏРґ" Style="{StaticResource BtnGhost}" Padding="8,4" Margin="0,0,4,0"
                                                    Click="OpenMemoryReview_Click"/>
                                            <Button Content="Р§РёСЃС‚РєР°" Style="{StaticResource BtnGhost}" Padding="8,4" Margin="0,0,4,0"
                                                    Click="OpenMemoryCleanup_Click"/>
                                            <Button Content="Р—Р°РґР°С‡С–" Style="{StaticResource BtnGhost}" Padding="8,4" Margin="0,0,4,0"
                                                    Click="OpenTasksQueue_Click"/>
                                            <Button Content="РђСЂС…С–С‚РµРєС‚СѓСЂР°" Style="{StaticResource BtnGhost}" Padding="8,4" Margin="0,0,4,0"
                                                    Click="OpenVaultArchitecture_Click"/>
                                        </WrapPanel>
                                    </Grid>
                                </Border>
                                <TextBox x:Name="NoteEditor" Grid.Row="2"
                                         Style="{StaticResource InputBox}"
                                         AcceptsReturn="True" TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         FontFamily="Consolas" FontSize="12"
                                         BorderThickness="0" Padding="16"/>
                                <Border Grid.Row="3" Background="{DynamicResource AccentBgDarker}"
                                        BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="0,1,0,0" Padding="12,5">
                                    <TextBlock x:Name="NoteStatsLabel" Foreground="{DynamicResource Brush_1A3020}" FontSize="10"/>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>

                    <!-- в•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ HEALTH TAB в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•— -->
