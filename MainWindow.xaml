                                           Foreground="{DynamicResource AccentBase}" FontFamily="Consolas" Margin="0,0,0,16"/>

                                <!-- Month navigation -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="30"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="CalPrevBtn" Content="в—Ђ" Style="{StaticResource BtnTab}"
                                            Click="CalPrev_Click" Width="26" Height="26" Padding="0" FontSize="10"/>
                                    <TextBlock x:Name="CalMonthLabel" Grid.Column="1"
