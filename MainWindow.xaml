                                               Foreground="{DynamicResource AccentBase}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Button x:Name="CalNextBtn" Grid.Column="2" Content="в–¶" Style="{StaticResource BtnTab}"
                                            Click="CalNext_Click" Width="26" Height="26" Padding="0" FontSize="10"/>
