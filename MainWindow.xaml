                                        <StackPanel Margin="0,0,0,8"><TextBlock Text="active" FontSize="9" Foreground="{DynamicResource AccentDim}"/><TextBlock x:Name="MemTabConfirmedText" Text="?" FontSize="18" FontFamily="Consolas" FontWeight="Bold" Foreground="{DynamicResource Brush_Ok}"/></StackPanel>
                                        <StackPanel Margin="0,0,10,8"><TextBlock Text="priority" FontSize="9" Foreground="{DynamicResource AccentDim}"/><TextBlock x:Name="MemTabHighImpText" Text="?" FontSize="18" FontFamily="Consolas" FontWeight="Bold" Foreground="#E25A6A"/></StackPanel>
                                        <StackPanel Margin="0,0,0,8"><TextBlock Text="clusters" FontSize="9" Foreground="{DynamicResource AccentDim}"/><TextBlock x:Name="MemTabCatCountText" Text="?" FontSize="18" FontFamily="Consolas" FontWeight="Bold" Foreground="{DynamicResource AccentBase}"/></StackPanel>
                                    </UniformGrid>
                                    <StackPanel Grid.Row="2">
                                        <TextBlock Text="DATA SOURCES" FontSize="9" FontFamily="Consolas" Foreground="{DynamicResource AccentDim}" Margin="0,0,0,8"/>
                                        <TextBlock x:Name="MemoryCortexSourcesText" Text="Vault online&#x0a;Index cache synced&#x0a;Graph engine active" FontSize="10" FontFamily="Consolas" Foreground="{DynamicResource AccentText}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <TextBlock Grid.Row="3" x:Name="MemoryCortexDensityText" Text="density --" FontSize="10" FontFamily="Consolas" Foreground="{DynamicResource AccentDim}"/>
                                </Grid>
                            </Border>

                            <Border Grid.Column="2" Background="{DynamicResource AccentBgPanel}"
                                    BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="1" CornerRadius="10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="58"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="38"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="0,0,0,1" Padding="14,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal">
                                                <StackPanel Margin="0,0,34,0"><TextBlock Text="ACTIVE QUERY" FontSize="8" FontFamily="Consolas" Foreground="{DynamicResource AccentDim}"/><TextBlock x:Name="MemoryActiveQueryText" Text="&quot;memory cortex&quot;" FontSize="11" FontFamily="Consolas" Foreground="{DynamicResource AccentBase}"/></StackPanel>
                                                <StackPanel><TextBlock Text="MODE" FontSize="8" FontFamily="Consolas" Foreground="{DynamicResource AccentDim}"/><TextBlock Text="associative thinking" FontSize="11" FontFamily="Consolas" Foreground="{DynamicResource AccentText}"/></StackPanel>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="LIVE" FontSize="9" FontFamily="Consolas" Foreground="#E25A6A" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                    <skia:SKElement x:Name="MemoryCortexSkia" Grid.Row="1" ClipToBounds="True"
                                                    PaintSurface="MemoryCortexSkia_PaintSurface"
                                                    MouseLeftButtonDown="MemoryCortexSkia_MouseLeftButtonDown"/>
                                    <Border Grid.Row="2" BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="0,1,0,0" Padding="12,6">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="person" Foreground="#E25A6A" FontSize="9" FontFamily="Consolas" Margin="0,0,18,0"/>
                                            <TextBlock Text="project" Foreground="#76B7E8" FontSize="9" FontFamily="Consolas" Margin="0,0,18,0"/>
                                            <TextBlock Text="world / lore" Foreground="#68E6D6" FontSize="9" FontFamily="Consolas" Margin="0,0,18,0"/>
                                            <TextBlock Text="ideas" Foreground="{DynamicResource AccentBase}" FontSize="9" FontFamily="Consolas" Margin="0,0,18,0"/>
                                            <TextBlock Text="system" Foreground="#B0B0C0" FontSize="9" FontFamily="Consolas"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                            <StackPanel Grid.Column="4">
                                <Border Background="{DynamicResource AccentBgCard}" BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,0,10">
                                    <StackPanel><TextBlock Text="MEMORY INSPECTOR" FontSize="9" FontFamily="Consolas" Foreground="{DynamicResource AccentDim}" Margin="0,0,0,10"/><TextBlock x:Name="MemoryInspectorTitle" Text="select node" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource AccentTextLight}" TextWrapping="Wrap"/><TextBlock x:Name="MemoryInspectorMeta" Text="type -- / importance -- / confirmations --" FontSize="10" FontFamily="Consolas" Foreground="{DynamicResource AccentDim}" TextWrapping="Wrap" Margin="0,8,0,0"/><ProgressBar x:Name="MemoryInspectorImportanceBar" Height="4" Minimum="0" Maximum="100" Value="0" Foreground="#E25A6A" Background="{DynamicResource AccentBgDarker}" Margin="0,10,0,0"/></StackPanel>
                                </Border>
                                <Border Background="{DynamicResource AccentBgCard}" BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,0,10"><StackPanel><TextBlock Text="LINKS" FontSize="9" FontFamily="Consolas" FontWeight="Bold" Foreground="#E25A6A" Margin="0,0,0,8"/><ItemsControl x:Name="MemoryLinksList"/></StackPanel></Border>
                                <Border Background="{DynamicResource AccentBgCard}" BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,0,10"><StackPanel><TextBlock Text="ACTIVITY FEED" FontSize="9" FontFamily="Consolas" FontWeight="Bold" Foreground="#E25A6A" Margin="0,0,0,8"/><ItemsControl x:Name="MemoryActivityFeed"/></StackPanel></Border>
                                <Border Background="{DynamicResource AccentBgCard}" BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="1" CornerRadius="10" Padding="14"><StackPanel><TextBlock Text="THOUGHT FLOW" FontSize="9" FontFamily="Consolas" FontWeight="Bold" Foreground="#E25A6A" Margin="0,0,0,8"/><ItemsControl x:Name="MemoryThoughtFlow"/></StackPanel></Border>
                            </StackPanel>
                        </Grid>

                        <Border Grid.Row="2" Background="{DynamicResource AccentBgDarker}" BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="0,1,0,0" Padding="14,10">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="140"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBox x:Name="MemoryCortexSearchBox" Style="{StaticResource InputBox}" Height="38" Padding="10,8" TextChanged="MemoryCortexSearchBox_TextChanged" ToolTip="Search memory cortex..."/>
                                <Button Grid.Column="1" Content="Search" Style="{StaticResource BtnGhost}" Width="42" Height="38" Margin="8,0,12,0" Click="MemTabRefresh_Click"/>
                                <Slider Grid.Column="2" x:Name="MemoryCortexZoomSlider" Minimum="0.65" Maximum="1.4" Value="1" VerticalAlignment="Center" ValueChanged="MemoryCortexZoomSlider_ValueChanged"/>
                                <Button Grid.Column="3" Content="auto focus" Style="{StaticResource BtnGhost}" Height="38" Padding="12,0" Margin="12,0,0,0" Click="MemTabRefresh_Click"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- в•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ PULSE TAB в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•— -->
                    <Grid x:Name="PulseTab" Visibility="Collapsed" Background="Transparent"
                          SizeChanged="PulseTab_SizeChanged">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="0"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Border Grid.Row="0" Background="{DynamicResource AccentBgDarker}"
                                BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="0,0,0,1" Padding="20,12">
                            <Grid>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="GALAXY WATCH LINK" FontSize="12" FontFamily="Consolas" FontWeight="Bold"
                                               Foreground="{DynamicResource AccentBase}" VerticalAlignment="Center"/>
                                    <TextBlock Text=" / verified cardiac telemetry" FontSize="9" FontFamily="Consolas"
                                               Foreground="{DynamicResource AccentDim}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <TextBlock x:Name="PulseTabBpmBig" Text="--"
                                               FontSize="28" FontWeight="Bold" FontFamily="Consolas"
                                               Foreground="{DynamicResource RgbRedBrush}" VerticalAlignment="Center">
                                        <TextBlock.Effect>
                                            <DropShadowEffect Color="#E25A6A" BlurRadius="8" ShadowDepth="0" Opacity="0.28"/>
                                        </TextBlock.Effect>
                                    </TextBlock>
                                    <StackPanel VerticalAlignment="Center" Margin="6,0,0,0">
                                        <TextBlock Text="BPM / VERIFIED" FontSize="9" FontFamily="Consolas"
                                                   Foreground="{DynamicResource AccentDim}"/>
                                        <TextBlock x:Name="PulseTabStateLabel" Text="MONITORING"
                                                   FontSize="8" FontFamily="Consolas" Foreground="{DynamicResource RgbRedBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ECG Canvas -->
                        <Border Grid.Row="1" Visibility="Collapsed" Background="{DynamicResource AccentBgPanel}"
                                BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="1" CornerRadius="8"
                                Padding="20,10" Margin="20,12,20,0">
                            <Grid>
                                <TextBlock Text="ECG" FontSize="8" FontFamily="Consolas" Foreground="{DynamicResource RgbRedBrush}"
                                           VerticalAlignment="Top" HorizontalAlignment="Left" Opacity="0.6"/>
                                <Canvas x:Name="PulseEcgCanvas" ClipToBounds="True"/>
                            </Grid>
                        </Border>

                        <!-- Status row -->
                        <Grid Grid.Row="2" Margin="20,12,20,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="{DynamicResource AccentBgCard}"
                                    BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="1" CornerRadius="8"
                                    Padding="12,10" Margin="0,0,6,0">
                                <StackPanel>
                                    <TextBlock Text="CURRENT" FontSize="8" FontFamily="Consolas" Foreground="{DynamicResource AccentDim}"/>
                                    <TextBlock x:Name="PulseTabCurText" Text="вЂ”" FontSize="20" FontWeight="Bold"
                                               Foreground="{DynamicResource RgbRedBrush}"/>
                                    <TextBlock Text="bpm" FontSize="8" Foreground="{DynamicResource AccentDim}"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Background="{DynamicResource AccentBgCard}"
                                    BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="1" CornerRadius="8"
                                    Padding="12,10" Margin="0,0,6,0">
                                <StackPanel>
                                    <TextBlock Text="BASELINE" FontSize="8" FontFamily="Consolas" Foreground="{DynamicResource AccentDim}"/>
                                    <TextBlock x:Name="PulseTabBaseText" Text="вЂ”" FontSize="20" FontWeight="Bold"
                                               Foreground="{DynamicResource Brush_Info}"/>
                                    <TextBlock Text="bpm" FontSize="8" Foreground="{DynamicResource AccentDim}"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Background="{DynamicResource AccentBgCard}"
                                    BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="1" CornerRadius="8"
                                    Padding="12,10" Margin="0,0,6,0">
                                <StackPanel>
                                    <TextBlock Text="HRV RMSSD" FontSize="8" FontFamily="Consolas" Foreground="{DynamicResource AccentDim}"/>
                                    <TextBlock x:Name="PulseTabHrvText" Text="вЂ”" FontSize="20" FontWeight="Bold"
                                               Foreground="{DynamicResource AccentBase}"/>
                                    <TextBlock Text="ms" FontSize="8" Foreground="{DynamicResource AccentDim}"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="3" Background="{DynamicResource AccentBgCard}"
                                    BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="1" CornerRadius="8"
                                    Padding="12,10">
                                <StackPanel>
                                    <TextBlock Text="MIN / MAX" FontSize="8" FontFamily="Consolas" Foreground="{DynamicResource AccentDim}"/>
                                    <TextBlock x:Name="PulseTabMinMaxText" Text="вЂ” / вЂ”" FontSize="16" FontWeight="Bold"
                                               Foreground="{DynamicResource AccentText}"/>
                                    <TextBlock Text="5 min range" FontSize="8" Foreground="{DynamicResource AccentDim}"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Bridge / watch link row -->
                        <Grid Grid.Row="3" Margin="20,12,20,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="1.4*"/>
                                <ColumnDefinition Width="1.4*"/>
                                <ColumnDefinition Width="1.6*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="{DynamicResource AccentBgCard}"
                                    BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="1" CornerRadius="8"
                                    Padding="12,8" Margin="0,0,6,0">
                                <StackPanel>
                                    <TextBlock Text="LINK" FontSize="8" FontFamily="Consolas" Foreground="{DynamicResource AccentDim}"/>
                                    <TextBlock x:Name="PulseBridgeLinkText" Text="WAITING" FontSize="15" FontWeight="Bold"
                                               FontFamily="Consolas" Foreground="{DynamicResource Brush_Warn}" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="PulseBridgeReasonText" Text="watch/app route unknown" FontSize="9"
                                               FontFamily="Consolas" Foreground="{DynamicResource AccentDim}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Background="{DynamicResource AccentBgCard}"
                                    BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="1" CornerRadius="8"
                                    Padding="12,8" Margin="0,0,6,0">
                                <StackPanel>
                                    <TextBlock Text="WATCH APP" FontSize="8" FontFamily="Consolas" Foreground="{DynamicResource AccentDim}"/>
                                    <TextBlock x:Name="PulseBridgeWatchText" Text="not paired" FontSize="13" FontWeight="Bold"
                                               FontFamily="Consolas" Foreground="{DynamicResource AccentText}" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="PulseBridgeWatchDetailText" Text="poll -- В· ack --" FontSize="9"
                                               FontFamily="Consolas" Foreground="{DynamicResource AccentDim}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Background="{DynamicResource AccentBgCard}"
                                    BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="1" CornerRadius="8"
                                    Padding="12,8" Margin="0,0,6,0">
                                <StackPanel>
                                    <TextBlock Text="DESKTOP BRIDGE" FontSize="8" FontFamily="Consolas" Foreground="{DynamicResource AccentDim}"/>
                                    <TextBlock x:Name="PulseBridgeDesktopText" Text="server --" FontSize="13" FontWeight="Bold"
                                               FontFamily="Consolas" Foreground="{DynamicResource AccentText}" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="PulseBridgeDesktopDetailText" Text="samples 0 В· auth 0" FontSize="9"
                                               FontFamily="Consolas" Foreground="{DynamicResource AccentDim}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="3" Background="{DynamicResource AccentBgCard}"
                                    BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="1" CornerRadius="8"
                                    Padding="12,8">
                                <StackPanel>
                                    <TextBlock Text="LAST SEEN / ENDPOINT" FontSize="8" FontFamily="Consolas" Foreground="{DynamicResource AccentDim}"/>
                                    <TextBlock x:Name="PulseBridgeLastSeenText" Text="--" FontSize="13" FontWeight="Bold"
                                               FontFamily="Consolas" Foreground="{DynamicResource AccentText}" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="PulseBridgeEndpointText" Text="remote --" FontSize="9"
                                               FontFamily="Consolas" Foreground="{DynamicResource AccentDim}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Bridge setup row -->
                        <Border Grid.Row="4" Background="{DynamicResource AccentBgCard}"
                                BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="1" CornerRadius="8"
                                Padding="12" Margin="20,12,20,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="96"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1.4*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="PC PORT" FontSize="8" FontFamily="Consolas" Foreground="{DynamicResource AccentDim}"/>
                                    <TextBox x:Name="PulseBridgePortBox" Text="8787"
                                             FontSize="12" FontFamily="Consolas" Foreground="{DynamicResource AccentText}"
                                             Background="{DynamicResource AccentBgPanel}" BorderBrush="{DynamicResource AccentBgBorder2}"
                                             BorderThickness="1" Padding="6,5"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                    <TextBlock Text="PC IPS FOR WATCH (one per line)" FontSize="8" FontFamily="Consolas" Foreground="{DynamicResource AccentDim}"/>
                                    <TextBox x:Name="PulseBridgeUrlsInput" MinHeight="44" AcceptsReturn="True" TextWrapping="Wrap"
                                             FontSize="11" FontFamily="Consolas" Foreground="{DynamicResource AccentText}"
                                             Background="{DynamicResource AccentBgPanel}" BorderBrush="{DynamicResource AccentBgBorder2}"
                                             BorderThickness="1" Padding="6,5"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="0,0,8,0">
                                    <TextBlock Text="PAIR LOCK" FontSize="8" FontFamily="Consolas" Foreground="{DynamicResource AccentDim}"/>
                                    <TextBlock x:Name="PulseBridgePairLockText" Text="pc -- / token --"
                                               FontSize="11" FontFamily="Consolas" Foreground="{DynamicResource AccentText}"
                                               TextWrapping="Wrap" Margin="0,3,0,0"/>
                                    <TextBlock x:Name="PulseBridgeSetupHintText" Text="watch sends to PC; token locks it to this Kokonoe"
                                               FontSize="9" FontFamily="Consolas" Foreground="{DynamicResource AccentDim}"
                                               TextWrapping="Wrap" Margin="0,3,0,0"/>
                                </StackPanel>
                                <WrapPanel Grid.Column="3" VerticalAlignment="Center">
                                    <Button Content="Save + Restart" Click="PulseBridgeSaveRestart_Click"
                                            Style="{StaticResource BtnGhost}" FontFamily="Consolas" FontSize="11"
                                            Padding="10,6" Margin="0,0,6,6"/>
                                    <Button Content="Copy Setup" Click="PulseBridgeCopySetup_Click"
                                            Style="{StaticResource BtnGhost}" FontFamily="Consolas" FontSize="11"
                                            Padding="10,6" Margin="0,0,6,6"/>
                                    <Button Content="Fix Firewall" Click="PulseBridgeFixFirewall_Click"
                                            Style="{StaticResource BtnGhost}" FontFamily="Consolas" FontSize="11"
                                            Padding="10,6" Margin="0,0,6,6"/>
                                    <Button Content="Refresh Pair" Click="PulseBridgeRefreshPair_Click"
                                            Style="{StaticResource BtnGhost}" FontFamily="Consolas" FontSize="11"
                                            Padding="10,6" Margin="0,0,6,6"/>
                                    <Button Content="Restart Watch" Click="PulseBridgeRestartWatch_Click"
                                            Style="{StaticResource BtnGhost}" FontFamily="Consolas" FontSize="11"
                                            Padding="10,6" Margin="0,0,0,6"/>
                                </WrapPanel>
                            </Grid>
                        </Border>

                        <!-- Telemetry workspace -->
                        <Grid Grid.Row="5" Margin="20,12,20,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.15*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="1.15*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="1.05*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="320"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="{DynamicResource AccentBgCard}"
                                    BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="1" CornerRadius="8"
                                    Padding="12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="VITAL LOG" FontSize="9" FontFamily="Consolas" FontWeight="Bold"
                                               Foreground="{DynamicResource RgbGreenBrush}" Margin="0,0,0,10"/>
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl x:Name="PulseVitalLog">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="132"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding TimeStr}" FontSize="10" FontFamily="Consolas"
                                                                   Foreground="{DynamicResource AccentDim}" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding BpmStr}" FontSize="10" FontFamily="Consolas"
                                                                   Foreground="{DynamicResource RgbRedBrush}" TextWrapping="Wrap"
                                                                   HorizontalAlignment="Stretch" TextAlignment="Right"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                            <Border Grid.Column="2" Background="{DynamicResource AccentBgCard}"
                                    BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="1" CornerRadius="8"
                                    Padding="12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="54"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="HEART RATE В· LIVE WINDOW" FontSize="9" FontFamily="Consolas" FontWeight="Bold"
                                               Foreground="{DynamicResource RgbGreenBrush}" Margin="0,0,0,8"/>
                                    <Canvas x:Name="PulseHr24Canvas" Grid.Row="1" ClipToBounds="True"/>
                                    <UniformGrid Grid.Row="2" Columns="4" Margin="0,10,0,0">
                                        <StackPanel>
                                            <TextBlock Text="AVG" FontSize="8" FontFamily="Consolas" Foreground="{DynamicResource AccentDim}"/>
                                            <TextBlock x:Name="PulseAvgText" Text="-- bpm" FontSize="13" FontFamily="Consolas" Foreground="{DynamicResource AccentText}"/>
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="PEAK" FontSize="8" FontFamily="Consolas" Foreground="{DynamicResource AccentDim}"/>
                                            <TextBlock x:Name="PulsePeakText" Text="-- bpm" FontSize="13" FontFamily="Consolas" Foreground="{DynamicResource RgbRedBrush}"/>
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="LOWEST" FontSize="8" FontFamily="Consolas" Foreground="{DynamicResource AccentDim}"/>
                                            <TextBlock x:Name="PulseLowText" Text="-- bpm" FontSize="13" FontFamily="Consolas" Foreground="{DynamicResource Brush_Info}"/>
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="CONSISTENCY" FontSize="8" FontFamily="Consolas" Foreground="{DynamicResource AccentDim}"/>
                                            <TextBlock x:Name="PulseConsistencyText" Text="--%" FontSize="13" FontFamily="Consolas" Foreground="{DynamicResource AccentBase}"/>
                                        </StackPanel>
                                    </UniformGrid>
                                </Grid>
                            </Border>
                            <Border Grid.Column="4" Background="{DynamicResource AccentBgCard}"
                                    BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="1" CornerRadius="8"
                                    Padding="12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="RECENT EVENTS" FontSize="9" FontFamily="Consolas" FontWeight="Bold"
                                               Foreground="{DynamicResource RgbGreenBrush}" Margin="0,0,0,10"/>
                                    <ItemsControl x:Name="PulseRecentEvents" Grid.Row="1">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="58"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Time}" FontSize="9" FontFamily="Consolas"
                                                               Foreground="{DynamicResource AccentDim}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Text}" FontSize="10"
                                                               Foreground="{DynamicResource AccentText}" TextWrapping="Wrap"/>
                                                    <Ellipse Grid.Column="2" Width="5" Height="5" Fill="{Binding Brush}" Margin="8,6,0,0"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>
                            <StackPanel Grid.Column="6">
                                <Border Background="{DynamicResource AccentBgCard}"
                                        BorderBrush="{DynamicResource AccentBgBorder2}" BorderThickness="1" CornerRadius="8"
                                        Padding="14" Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="WATCH PULSE" FontSize="9" FontFamily="Consolas" FontWeight="Bold" Foreground="{DynamicResource RgbGreenBrush}"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,12,0,6">
                                                <TextBlock x:Name="PulseSideBpmText" Text="--" FontSize="34" FontWeight="Bold"
